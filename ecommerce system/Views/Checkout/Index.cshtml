@model ecommerce_system.Models.Cart
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";

    decimal subtotal = 0;
    foreach (var item in Model.CartItems)
        if (item.Proudect != null)
            subtotal += item.Quantity * item.Proudect.Price;

    decimal total    = subtotal;
}


 @section Styles
    {
        <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" / >
}


.co-sum-row {
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:14px; font-size:14px; color:var(--text-sub);
}
[data-theme="dark"] .co-sum-row { font-family:'Space Grotesk',sans-serif; }
[data-theme="light"] .co-sum-row { font-family:'Jost',sans-serif; }
.co-sum-row span:last-child {
    font-family:var(--heading); color:var(--text); font-size:16px;
}
[data-theme="light"] .co-sum-row span:last-child { font-weight:700; }

.co-sum-div { height:1px; background:var(--border); margin:16px 0 20px; }
.co-sum-total { margin-bottom:28px; }
.co-sum-total span { font-size:15px !important; font-weight:500; }
.co-sum-total span:last-child { font-size:28px !important; color:var(--accent) !important; }
[data-theme="light"] .co-sum-total span:last-child { font-weight:800 !important; }

.co-pay-btn {
    display:block; width:100%;
    background:var(--accent); color:var(--btn1-fg);
    border:none; cursor:pointer; font-weight:700;
    text-align:center; text-decoration:none;
    transition:opacity .2s, transform .2s;
    margin-bottom:14px;
}
[data-theme="dark"] .co-pay-btn {
    padding:18px 24px; font-family:'Space Grotesk',sans-serif;
    font-size:11px; letter-spacing:3px; text-transform:uppercase;
    clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);
}
[data-theme="light"] .co-pay-btn {
    padding:18px 24px; font-family:'Jost',sans-serif;
    font-size:12px; letter-spacing:2px; text-transform:uppercase;
    border-radius:4px;
}
.co-pay-btn:hover { opacity:.88; transform:translateY(-2px); }

.co-pay-btn::before { content:'✓ '; }

.co-back-link {
    display:block; text-align:center; font-size:12px;
    color:var(--text-dim); text-decoration:none;
    letter-spacing:1px; transition:color .2s; margin-top:8px;
}
[data-theme="dark"] .co-back-link { font-family:'Space Grotesk',sans-serif; }
[data-theme="light"] .co-back-link { font-family:'Jost',sans-serif; }
.co-back-link:hover { color:var(--accent); }

.co-secure {
    display:flex; flex-direction:column; gap:8px;
    margin-top:20px; padding-top:20px; border-top:1px solid var(--border);
}
.co-secure-item {
    display:flex; align-items:center; gap:8px;
    font-size:11px; color:var(--text-dim); letter-spacing:.5px;
}
[data-theme="dark"] .co-secure-item { font-family:'Space Grotesk',sans-serif; }
[data-theme="light"] .co-secure-item { font-family:'Jost',sans-serif; }
.co-secure-item span:first-child { font-size:14px; }

.co-ship-banner {
    text-align:center; font-size:11px; letter-spacing:1px;
    color:#4edea3; margin-bottom:16px; font-weight:600;
}
[data-theme="dark"] .co-ship-banner { font-family:'Space Grotesk',sans-serif; }
[data-theme="light"] .co-ship-banner { font-family:'Jost',sans-serif; }

@@media (max-width:900px){
    .co-layout { grid-template-columns:1fr; padding:24px 20px; }
    .co-hd { padding:48px 20px 32px; }
    .co-steps { padding:16px 20px; flex-wrap:wrap; gap:8px; }
    .co-step-sep { display:none; }
    .co-summary { position:static; }
    .co-item { grid-template-columns:60px 1fr; }
    .co-item-price-col { grid-column:2; text-align:left; }
    .co-alert { margin:16px 20px 0; }
}
</style>
}

<div class="co-page">

    <div class="co-hd">
        <p class="co-eye">Secure Payment</p>
        <h1 class="co-title">ORDER<br /><span class="co-title-accent">CHECKOUT</span></h1>
        <p class="co-sub-lbl">Review your items and complete your purchase securely.</p>
    </div>

    <div class="co-steps">
        <div class="co-step done">
            <div class="co-step-num">✓</div>
            <span>Cart</span>
        </div>
        <div class="co-step-sep"></div>
        <div class="co-step active">
            <div class="co-step-num">2</div>
            <span>Review</span>
        </div>
        <div class="co-step-sep"></div>
        <div class="co-step">
            <div class="co-step-num">3</div>
            <span>Payment</span>
        </div>
        <div class="co-step-sep"></div>
        <div class="co-step">
            <div class="co-step-num">4</div>
            <span>Confirmed</span>
        </div>
    </div>

    @if (TempData["error"] != null)
    {
        <div class="co-alert">⚠ @TempData["error"]</div>
    }

    <div class="co-layout">

        <div>
            <div class="co-panel">
                <div class="co-panel-hd">
                    <span class="co-panel-ttl">Order Items</span>
                    <span class="co-panel-count">@Model.CartItems.Count() item@(Model.CartItems.Count() != 1 ? "s" : "")</span>
                </div>

                @foreach (var item in Model.CartItems)
                {
                    if (item.Proudect == null) continue;
                    var lineTotal = item.Quantity * item.Proudect.Price;

                    <div class="co-item">
                        <div class="co-item-img">
                            @{
                                var img = item.Proudect.Img ?? "";
                                if (img.StartsWith("/") || img.StartsWith("http"))
                                {
                                    <img src="@img" alt="@item.Proudect.Name" />
                                }
                                else
                                {
                                    <span class="co-item-emoji">@(string.IsNullOrEmpty(img) ? "📦" : img)</span>
                                }
                            }
                        </div>
                        <div>
                            <p class="co-item-brand">@(item.Proudect.Name.Split(' ').FirstOrDefault() ?? "")</p>
                            <p class="co-item-name">@item.Proudect.Name</p>
                            <span class="co-item-qty">QTY: @item.Quantity</span>
                        </div>
                        <div class="co-item-price-col">
                            <p class="co-item-unit">$@item.Proudect.Price.ToString("F2") / ea</p>
                            <p class="co-item-line">$@lineTotal.ToString("F2")</p>
                        </div>
                    </div>
                }
            </div>

            <div style="margin-top:16px; padding:16px 28px; border:1px solid var(--border); background:var(--surface); display:flex; align-items:center; justify-content:space-between;">
                <a href="/Cart" style="font-size:12px; color:var(--text-dim); text-decoration:none; letter-spacing:1px; transition:color .2s;"
                   onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'">
                    ← Edit Cart
                </a>
                <span style="font-size:11px; color:var(--text-dim); letter-spacing:.5px;">
                    🛒 Ready to complete
                </span>
            </div>
        </div>

        <div class="co-summary">
            <div class="co-summary-inner">
                <h2 class="co-sum-ttl">Order Summary</h2>


                <div class="co-sum-row">
                    <span>Subtotal (@Model.CartItems.Sum(i => i.Quantity) items)</span>
                    <span>$@subtotal.ToString("F2")</span>
                </div>
                <div class="co-sum-row">
                    <span>Tax</span>
                    <span>Calculated at payment</span>
                </div>

                <div class="co-sum-div"></div>

                <div class="co-sum-row co-sum-total">
                    <span>Total</span>
                    <span>$@total.ToString("F2")</span>
                </div>

                <form asp-action="ProcessPayment" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="co-pay-btn">
                        Confirm Order - $@total.ToString("F2")
                    </button>
                </form>

                <a href="/Cart" class="co-back-link">← Return to Cart</a>

                <div class="co-secure">
                    <div class="co-secure-item">
                        <span>🚀</span><span>Fast Order Processing</span>
                    </div>
                    <div class="co-secure-item">
                        <span>↩</span><span>30-Day Return Policy</span>
                    </div>
                    <div class="co-secure-item">
                        <span>📦</span><span>Fast & Tracked Shipping</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
