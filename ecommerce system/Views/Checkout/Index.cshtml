@model ecommerce_system.Models.Cart

@{
    ViewData["Title"] = "Checkout";
}

<div class="container my-5">
    <h2>Checkout Summary</h2>
    
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Order Items</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CartItems)
                            {
                                <tr>
                                    <td>
                                        @if (item.Proudect != null)
                                        {
                                            @item.Proudect.Name
                                        }
                                    </td>
                                    <td>
                                        @if (item.Proudect != null)
                                        {
                                            @item.Proudect.Price.ToString("C")
                                        }
                                    </td>
                                    <td>@item.Quantity</td>
                                    <td>
                                        @if (item.Proudect != null)
                                        {
                                            @((item.Quantity * item.Proudect.Price).ToString("C"))
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Order Total</h5>
                </div>
                <div class="card-body">
                    @{
                        decimal total = 0;
                        foreach (var item in Model.CartItems)
                        {
                            if (item.Proudect != null)
                            {
                                total += item.Quantity * item.Proudect.Price;
                            }
                        }
                    }
                    <h4>Total Amount: @total.ToString("C")</h4>
                    <hr />
                    <form asp-action="ProcessPayment" method="post">
                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="fas fa-lock"></i> Pay Securely with Stripe
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
