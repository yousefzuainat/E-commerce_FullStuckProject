<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus Commerce</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <!-- SweetAlert2 for Toasts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        "surface-container": "#192029",
                        "on-tertiary-fixed-variant": "#930013",
                        "inverse-primary": "#005ac2",
                        "surface-bright": "#333a44",
                        "primary-fixed-dim": "#adc6ff",
                        "primary": "#4d8eff",
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @@layer utilities {
            .glass-panel {
                @@apply bg-surface-container/80 backdrop-blur-md border border-white/10;
            }
        }
        body {
            @@apply bg-[#0f141a] text-gray-100 font-sans antialiased selection:bg-primary selection:text-white min-h-screen flex flex-col overflow-x-hidden;
        }
        /* Custom scrollbar for better look */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #0f141a;
        }
        ::-webkit-scrollbar-thumb {
            background: #333a44;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #4d8eff;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-[#0f141a] text-gray-100 min-h-screen flex flex-col">
    <!-- Navigation Header -->
    <header class="glass-panel sticky top-0 z-[60] h-[76px] flex items-center shadow-2xl">
        <nav class="container mx-auto px-6 flex items-center justify-between">
            <div class="flex items-center gap-8 ml-4">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-blue-600 flex items-center justify-center shadow-lg shadow-primary/20 group-hover:shadow-primary/40 transition-all duration-300">
                        <span class="material-symbols-outlined text-white">shopping_bag</span>
                    </div>
                    <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400">Nexus Commerce</span>
                </a>
                <div class="hidden lg:flex items-center gap-6 text-sm font-medium">
                    <a asp-controller="Home" asp-action="Index" class="text-gray-300 hover:text-white transition-colors">Dashboard</a>
                    <a asp-controller="Proudects" asp-action="Index" class="text-gray-300 hover:text-white transition-colors">Products</a>
                    <a asp-controller="Categories" asp-action="Index" class="text-gray-300 hover:text-white transition-colors">Category</a>
                    <a href="#" class="text-gray-300 hover:text-white transition-colors">Orders</a>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="relative hidden sm:block">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">search</span>
                    <input type="text" placeholder="Search..." class="bg-white/5 border border-white/10 rounded-full pl-10 pr-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-white placeholder-gray-500 w-48 xl:w-64 transition-all" />
                </div>
                
                <div class="flex items-center gap-2">
                    <partial name="_LoginPartial" />
                    <!-- Mobile Menu Toggle -->
                    <button id="mobile-menu-toggle" class="md:hidden w-10 h-10 flex items-center justify-center text-gray-300 hover:text-white bg-white/5 rounded-lg border border-white/10 transition-all">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                </div>
            </div>
        </nav>
    </header>

    <div class="flex-grow flex relative">
        <!-- Sidebar Navigation -->
        <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 glass-panel border-r border-white/5 flex flex-col transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out md:top-[76px] md:z-40">
            <div class="flex-1 py-6 flex flex-col gap-2 overflow-y-auto px-4">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-primary bg-primary/10 border border-primary/20" : "")">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="font-bold">Dashboard</span>
                </a>
                <a asp-controller="Proudects" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Proudects" ? "text-primary bg-primary/10 border border-primary/20" : "")">
                    <span class="material-symbols-outlined">inventory_2</span>
                    <span class="font-bold">Products</span>
                </a>
                <a asp-controller="Categories" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "text-primary bg-primary/10 border border-primary/20" : "")">
                    <span class="material-symbols-outlined">category</span>
                    <span class="font-bold">Category</span>
                </a>
                <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span class="font-bold">Orders</span>
                </a>
                <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                    <span class="material-symbols-outlined">group</span>
                    <span class="font-bold">Customers</span>
                </a>
            </div>

            <div class="p-4 border-t border-white/5">
                <div class="bg-gradient-to-br from-primary/10 to-blue-600/10 rounded-2xl p-4 border border-primary/20">
                    <p class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-1">System Health</p>
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                        <span class="text-xs text-gray-400 font-medium">All systems active</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content area -->
        <main class="flex-1 w-full md:ml-64 min-h-[calc(100vh-76px)] bg-[#0d1117] relative z-10 overflow-x-hidden transition-all duration-300">
            <div class="container mx-auto px-4 sm:px-8 py-8">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="glass-panel border-t border-white/5 py-10 z-[60] relative">
        <div class="container mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">shopping_bag</span>
                <span class="font-bold text-gray-200">Nexus Commerce</span>
            </div>
            <p class="text-sm text-gray-400">&copy; 2026 Nexus Commerce. All rights reserved.</p>
            <div class="flex gap-4">
                <a href="#" class="text-gray-400 hover:text-white transition-colors"><span class="material-symbols-outlined text-xl">help</span></a>
                <a href="#" class="text-gray-400 hover:text-white transition-colors"><span class="material-symbols-outlined text-xl">settings</span></a>
            </div>
        </div>
    </footer>

    <!-- Scripts needed for MVC validation and functionality -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Toast Notifications -->
    <script>
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            background: '#192029',
            color: '#fff',
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        @if (TempData["success"] != null)
        {
            <text>
            Toast.fire({
                icon: 'success',
                title: '@TempData["success"]'
            });
            </text>
        }
        
        @if (TempData["info"] != null)
        {
            <text>
            Toast.fire({
                icon: 'info',
                title: '@TempData["info"]'
            });
            </text>
        }
        
        @if (TempData["error"] != null)
        {
            <text>
            Toast.fire({
                icon: 'error',
                title: '@TempData["error"]'
            });
            </text>
        }
    </script>
</body>
</html>
