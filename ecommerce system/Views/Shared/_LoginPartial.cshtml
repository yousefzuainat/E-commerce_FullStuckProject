@using Microsoft.AspNetCore.Identity
@using ecommerce_system.Models
@inject SignInManager<AppliactionUser> SignInManager
@inject UserManager<AppliactionUser> UserManager

 <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet"> 

<style>
    :root {
        --nav-accent: #c9a96e;
        --nav-text: #f0ece4;
        --nav-muted: #888;
        --nav-hover-bg: rgba(201,169,110,.12);
        --nav-transition: .25s cubic-bezier(.4,0,.2,1);
    }

    .auth-nav {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-family: 'DM Sans', sans-serif;
    }

    .auth-nav .nav-pill {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .45rem 1.1rem;
        border-radius: 50px;
        font-size: .875rem;
        font-weight: 500;
        letter-spacing: .01em;
        text-decoration: none;
        transition: background var(--nav-transition),
                    color var(--nav-transition),
                    box-shadow var(--nav-transition);
        cursor: pointer;
        border: none;
        outline: none;
        line-height: 1;
    }

    .auth-nav .nav-pill--ghost {
        color: var(--nav-text);
        background: transparent;
        border: 1px solid rgba(240,236,228,.18);
    }
    .auth-nav .nav-pill--ghost:hover {
        background: var(--nav-hover-bg);
        border-color: var(--nav-accent);
        color: var(--nav-accent);
        box-shadow: 0 0 0 3px rgba(201,169,110,.12);
    }

    .auth-nav .nav-pill--filled {
        color: #0f0f0f;
        background: var(--nav-accent);
        border: 1px solid var(--nav-accent);
    }
    .auth-nav .nav-pill--filled:hover {
        background: #d4b07e;
        box-shadow: 0 4px 18px rgba(201,169,110,.35);
        color: #0f0f0f;
    }

    .auth-nav .nav-sep {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--nav-muted);
        flex-shrink: 0;
    }

    .auth-nav .nav-greeting {
        font-family: 'Playfair Display', serif;
        font-size: .9rem;
        color: var(--nav-accent);
        white-space: nowrap;
    }

    .auth-nav svg {
        width: 15px;
        height: 15px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        flex-shrink: 0;
    }

    .auth-nav form {
        margin: 0;
        padding: 0;
        display: inline-flex;
    }
</style>

<ul class="navbar-nav auth-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-pill nav-pill--ghost"
           asp-area="Identity"
           asp-page="/Account/Manage/Index">
            <svg viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            <span class="nav-greeting">
                @((await UserManager.GetUserAsync(User))?.FullName ?? User.Identity?.Name)
            </span>
        </a>
    </li>

    <li class="nav-item">
        <form asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index","Home",new{area=""})">
            <button type="submit" class="nav-pill nav-pill--filled">
                <svg viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-pill nav-pill--ghost"
           asp-area="Identity"
           asp-page="/Account/Register">
            <svg viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <line x1="19" y1="8" x2="19" y2="14"/>
                <line x1="22" y1="11" x2="16" y2="11"/>
            </svg>
            Register
        </a>
    </li>

    <li class="nav-item nav-sep" aria-hidden="true"></li>

    <li class="nav-item">
        <a class="nav-pill nav-pill--filled"
           asp-area="Identity"
           asp-page="/Account/Login">
            <svg viewBox="0 0 24 24">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" y1="12" x2="3" y2="12"/>
            </svg>
            Login
        </a>
    </li>
}
</ul>