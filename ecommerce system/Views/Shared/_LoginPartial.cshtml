@using Microsoft.AspNetCore.Identity
@using ecommerce_system.Models
@inject SignInManager<AppliactionUser> SignInManager
@inject UserManager<AppliactionUser> UserManager

<ul class="flex items-center gap-4">
@if (SignInManager.IsSignedIn(User))
{
    <li class="flex items-center gap-4">
        <a class="text-gray-300 hover:text-white transition-colors text-sm font-medium flex items-center gap-2" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage Account">
            <span class="material-symbols-outlined text-lg">account_circle</span>
            <span class="hidden sm:inline">@((await UserManager.GetUserAsync(User))?.FullName ?? User.Identity?.Name)</span>
        </a>
        <form class="inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-all">
                Logout
            </button>
        </form>
    </li>
}
else
{
    <li>
        <a class="text-gray-300 hover:text-white transition-colors text-sm font-medium px-2" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li>
        <a class="bg-primary hover:bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold shadow-lg shadow-primary/20 transition-all" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
