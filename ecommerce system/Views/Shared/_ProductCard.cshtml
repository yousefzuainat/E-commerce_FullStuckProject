@* ═══════════════════════════════════════════════════════
     _ProductCard.cshtml  —  Unified product card partial
     Usage:
       @await Html.PartialAsync("_ProductCard", item)
     Model: ecommerce_system.Models.Proudect
════════════════════════════════════════════════════════ *@
@model ecommerce_system.Models.Proudect

<style>
    /* ── Card action row ── */
    .pag-actions {
        display: flex;
        gap: 8px;
        padding: 0 12px 14px;
    }

    /* Wishlist icon button */
    .pag-btn-wish {
        flex: 0 0 40px;
        height: 40px;
        background: transparent;
        border: 1.5px solid var(--border, rgba(255,255,255,.2));
        border-radius: 0;
        clip-path: polygon(5px 0%, 100% 0%, calc(100% - 5px) 100%, 0% 100%);
        color: var(--muted, #888);
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s, border-color .2s, color .2s;
    }

        .pag-btn-wish:hover {
            border-color: #ff6b6b;
            color: #ff6b6b;
            background: rgba(255,107,107,.1);
        }

        .pag-btn-wish.wished {
            border-color: #ff4040;
            color: #ff4040;
            background: rgba(255,64,64,.12);
        }

    [data-theme="light"] .pag-btn-wish {
        border-color: rgba(0,0,0,.18);
        color: #999;
    }

        [data-theme="light"] .pag-btn-wish:hover {
            border-color: #c84a00;
            color: #c84a00;
            background: rgba(200,74,0,.08);
        }

        [data-theme="light"] .pag-btn-wish.wished {
            border-color: #c84a00;
            color: #c84a00;
        }

    /* Cart button — stretches to fill remaining space */
    .pag-btn-danger {
        flex: 1;
        height: 40px;
        background: var(--accent, #f60);
        border: none;
        color: #000;
        border-radius: 0;
        clip-path: polygon(7px 0%, 100% 0%, calc(100% - 7px) 100%, 0% 100%);
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: .12em;
        text-transform: uppercase;
        cursor: pointer;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        transition: background .2s;
    }

        .pag-btn-danger:hover {
            background: #ff7a1a;
        }

        .pag-btn-danger.added {
            background: #2a9a4a !important;
            color: #fff;
        }

    [data-theme="light"] .pag-btn-danger {
        background: #c84a00;
        color: #fff;
    }

        [data-theme="light"] .pag-btn-danger:hover {
            background: #a63a00;
        }
</style>

@{
    var discount = Model.Discounts?
        .Select(d => d.DiscountPercent)
        .DefaultIfEmpty(0m)
        .Max() ?? 0m;

    var finalPrice = Model.Price * (1 - discount / 100m);

    int totalReviews = Model.Reviews?.Count ?? 0;
    double avgRating  = totalReviews > 0 ? Model.Reviews!.Average(r => r.Rating) : 0;
    int    fullStars  = (int)Math.Round(avgRating);

    var shortDesc = (Model.Description?.Length > 90)
        ? Model.Description.Substring(0, 90)
        : Model.Description ?? "";
    bool needsReadMore = (Model.Description?.Length ?? 0) > 90;
}

<div class="pag-card">

    @* <%-- ── Clickable area ── --%> *@
    <a asp-action="Details" asp-route-id="@Model.Id" class="prod-card-link">

        @* <%-- Thumbnail --%> *@
        <div class="pag-thumb">
            @if (!string.IsNullOrEmpty(Model.Img))
            {
                <img src="~@Model.Img" alt="@Model.Name" class="pag-thumb-img" asp-append-version="true" />
            }
            else
            {
                <span class="pag-thumb-emoji">🛍️</span>
            }

            @* ── Badge ── *@
            @if (discount > 0)
            {
                <span class="p-badge badge-sale">@discount.ToString("0")% OFF</span>
            }
            else if (totalReviews > 5)
            {
                <span class="p-badge badge-hot">HOT ★</span>
            }
            else
            {
                <span class="p-badge badge-new">NEW</span>
            }
        </div>

        @* <%-- Body --%> *@
        <div class="pag-body">
            <div class="pag-cat">@(Model.Category?.Name ?? "Uncategorized")</div>
            <div class="pag-name">@Model.Name</div>

            @* <%-- Fixed-height description with ellipsis + Read More --%> *@
            <div class="pag-desc-wrap">
                <span class="pag-desc-text">@shortDesc</span>@if (needsReadMore)
                {<span class="pag-read-more">…Read More</span>}
            </div>

            @* <%-- Stars --%> *@
            <p class="p-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <span style="color:@(i <= fullStars ? "#f5a623" : "#555");">★</span>
                }
                <span class="p-rc">(@totalReviews)</span>
            </p>

            @* <%-- Price --%> *@
            <div class="pag-foot">
                <span class="pag-price">@finalPrice.ToString("C")</span>
                @if (discount > 0)
                {
                    <span class="pag-old">@Model.Price.ToString("C")</span>
                }
            </div>
        </div>
    </a>

    @* <%-- ── Action buttons ── --%> *@
    <div class="pag-actions">
        @* Wishlist — no form, AJAX only, shows toast *@
        <button type="button"
                class="pag-btn pag-btn-wish"
                data-product-id="@Model.Id"
                onclick="toggleWishlist(this)"
                title="Add to Wishlist"
                aria-label="Add to wishlist">
            ♥
        </button>

        <button class="pag-btn pag-btn-danger"
                data-product-id="@Model.Id"
                onclick="addToCart(this)">
            Add To Cart
        </button>
    </div>

</div>
