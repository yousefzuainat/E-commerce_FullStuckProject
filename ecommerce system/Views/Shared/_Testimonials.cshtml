@model ecommerce_system.ViewModels.TestimonialsSection

@* ── Testimonials Section ─────────────────────────────────────────────── *@
<section class="sec sec-alt testi-sec reveal">

    <div class="sec-hd">
        <div>
            <p class="sec-eye">Real Customers</p>
            <h2 class="sec-ttl">WHAT PEOPLE<br />ARE SAYING</h2>
        </div>
    </div>

    <div class="testi-carousel-wrapper reveal">
        <button class="carousel-btn prev-btn" aria-label="Previous">
            <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <div class="testi-slider-container">
            <div class="testi-slider-track">
                @foreach (var t in Model.Items)
                {
                    <article class="testi-card reveal">

                        @* Quote icon *@
                        <div class="testi-quote">❝</div>

                        @* Stars *@
                        <div class="testi-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="@(i <= t.Rating ? "star-on" : "star-off")">★</span>
                            }
                        </div>

                        @* Body *@
                        <p class="testi-body">@t.Content</p>

                        @* Author row *@
                        <div class="testi-author">
                            <div class="testi-avatar">@t.Initials</div>
                            <div class="testi-meta">
                                <span class="testi-name">@t.AuthorName</span>
                                <span class="testi-time">@t.TimeAgo</span>
                            </div>
                        </div>

                    </article>
                }
            </div>
        </div>
        <button class="carousel-btn next-btn" aria-label="Next">
            <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
    </div>

</section>

<script>
    (function () {
        const initTestiSlider = () => {
            const track = document.querySelector('.testi-slider-track');
            const prevBtn = document.querySelector('.testi-carousel-wrapper .prev-btn');
            const nextBtn = document.querySelector('.testi-carousel-wrapper .next-btn');
            if (!track || !prevBtn || !nextBtn) return;
            if (track.dataset.sliderInitialized === "true") return;
            track.dataset.sliderInitialized = "true";
            
            let currentIndex = 0;
            const cards = track.querySelectorAll('.testi-card');
            const totalCards = cards.length;

            const getVisibleCardsCount = () => {
                if (window.innerWidth <= 768) return 1;
                if (window.innerWidth <= 1024) return 2;
                return 3;
            };

            const updateSlider = () => {
                const visibleCount = getVisibleCardsCount();
                const maxIndex = Math.max(0, totalCards - visibleCount);
                if (currentIndex > maxIndex) currentIndex = maxIndex;

                const firstCard = track.querySelector('.testi-card');
                if (!firstCard) return;

                const cardWidth = firstCard.offsetWidth;
                const gap = 24; // gap in pixels from CSS
                const translateX = -currentIndex * (cardWidth + gap);
                track.style.transform = `translateX(${translateX}px)`;

                // Update arrows states
                if (currentIndex === 0) {
                    prevBtn.style.opacity = '0.3';
                    prevBtn.style.pointerEvents = 'none';
                } else {
                    prevBtn.style.opacity = '1';
                    prevBtn.style.pointerEvents = 'auto';
                }

                if (currentIndex >= maxIndex) {
                    nextBtn.style.opacity = '0.3';
                    nextBtn.style.pointerEvents = 'none';
                } else {
                    nextBtn.style.opacity = '1';
                    nextBtn.style.pointerEvents = 'auto';
                }
            };

            prevBtn.addEventListener('click', () => {
                if (currentIndex > 0) {
                    currentIndex--;
                    updateSlider();
                }
            });

            nextBtn.addEventListener('click', () => {
                const visibleCount = getVisibleCardsCount();
                if (currentIndex < totalCards - visibleCount) {
                    currentIndex++;
                    updateSlider();
                }
            });

            window.addEventListener('resize', updateSlider);
            updateSlider();
            window.addEventListener('load', updateSlider);
            
            // Touch Swipe Support
            let startX = 0;
            let isDragging = false;

            track.addEventListener('touchstart', (e) => {
                startX = e.touches[0].clientX;
                isDragging = true;
            }, { passive: true });

            track.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const currentX = e.touches[0].clientX;
                const diffX = currentX - startX;
                
                if (Math.abs(diffX) > 50) {
                    isDragging = false;
                    if (diffX > 0) {
                        if (currentIndex > 0) {
                            currentIndex--;
                            updateSlider();
                        }
                    } else {
                        const visibleCount = getVisibleCardsCount();
                        if (currentIndex < totalCards - visibleCount) {
                            currentIndex++;
                            updateSlider();
                        }
                    }
                }
            }, { passive: true });

            track.addEventListener('touchend', () => {
                isDragging = false;
            });
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initTestiSlider);
        } else {
            initTestiSlider();
        }
    })();
</script>
