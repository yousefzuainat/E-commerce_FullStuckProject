@model ecommerce_system.Models.Proudect
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ecommerce_system.Models.AppliactionUser> SignInManager
@inject UserManager<ecommerce_system.Models.AppliactionUser>  UserManager

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";

    int reviewCount = Model.Reviews?.Count ?? 0;
    double avgRating = reviewCount > 0 ? Model.Reviews!.Average(r => r.Rating) : 0;

    var related = Model.Category?.Proudects?
        .Where(p => p.Id != Model.Id)
        .Take(4)
        .ToList();

    // Is the current user already reviewed this product?
    var currentUserId = UserManager.GetUserId(User);
    bool alreadyReviewed = Model.Reviews?.Any(r => r.UserId == currentUserId) ?? false;
}

@section Styles {
    <link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
}

<div class="pd-page">

    @* ── Breadcrumb ── *@
    <nav class="pd-crumb reveal">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="pd-crumb-sep">›</span>
        <a asp-action="Index">Products</a>
        @if (Model.Category != null)
        {
            <span class="pd-crumb-sep">›</span>
            <a asp-controller="Categories" asp-action="Details" asp-route-id="@Model.Category.Id">
                @Model.Category.Name
            </a>
        }
        <span class="pd-crumb-sep">›</span>
        <span class="pd-crumb-cur">@Model.Name</span>
    </nav>

    @* ── Main Layout ── *@
    <div class="pd-layout reveal">

        @* ── Gallery ── *@
        <div class="pd-gallery">
            <div class="pd-main-img" id="pdMainMedia">
                @if (!string.IsNullOrEmpty(Model.Img))
                {
                    <img src="@Model.Img" alt="@Model.Name" />
                }
                else
                {
                    <span class="pd-main-emoji">🛍️</span>
                }
                @if (reviewCount > 0)
                {
                    <span class="pd-badge-main badge-new">@reviewCount Reviews</span>
                }
            </div>
            <div class="pd-thumbs">
                <div class="pd-thumb-item active"
                     data-src="@Model.Img"
                     data-emoji="@(string.IsNullOrEmpty(Model.Img) ? "🛍️" : "")">
                    @if (!string.IsNullOrEmpty(Model.Img))
                    {
                        <img src="@Model.Img" alt="main" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else { <span>🛍️</span> }
                </div>
                <div class="pd-thumb-item" data-emoji="📦"><span>📦</span></div>
                <div class="pd-thumb-item" data-emoji="🔍"><span>🔍</span></div>
                <div class="pd-thumb-item" data-emoji="✨"><span>✨</span></div>
            </div>
        </div>

        @* ── Info ── *@
        <div class="pd-info">

            @if (Model.Category != null)
            {
                <div class="pd-eyebrow">
                    <span class="pd-category-tag">@Model.Category.Name</span>
                    @if (reviewCount > 0)
                    {
                        <span class="pd-stock-badge in-stock">
                            <span class="pd-stock-dot"></span>
                            @reviewCount Review@(reviewCount == 1 ? "" : "s")
                        </span>
                    }
                </div>
            }

            <h1 class="pd-name">@Model.Name</h1>

            @* Star summary *@
            @if (reviewCount > 0)
            {
                <div class="rv-summary-inline">
                    <span class="rv-stars-avg">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= Math.Round(avgRating) ? "rv-star filled" : "rv-star")">★</span>
                        }
                    </span>
                    <span class="rv-avg-num">@avgRating.ToString("0.0")</span>
                    <span class="rv-avg-count">(@reviewCount review@(reviewCount == 1 ? "" : "s"))</span>
                </div>
            }

            <div class="pd-price-block">
                <span class="pd-price">$@Model.Price.ToString("0.00")</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="pd-desc">@Model.Description</p>
            }

            <div class="pd-specs-mini">
                <div class="pd-spec-item">
                    <div class="pd-spec-lbl">SKU</div>
                    <div class="pd-spec-val">#@Model.Id.ToString("D6")</div>
                </div>
                @if (Model.Category != null)
                {
                    <div class="pd-spec-item">
                        <div class="pd-spec-lbl">Category</div>
                        <div class="pd-spec-val">@Model.Category.Name</div>
                    </div>
                }
                <div class="pd-spec-item">
                    <div class="pd-spec-lbl">Reviews</div>
                    <div class="pd-spec-val">@reviewCount</div>
                </div>
                <div class="pd-spec-item">
                    <div class="pd-spec-lbl">Price</div>
                    <div class="pd-spec-val">$@Model.Price.ToString("0.00")</div>
                </div>
            </div>

            <div class="pd-qty-row">
                <span class="pd-qty-label">Quantity</span>
                <div class="pd-qty-ctrl">
                    <button class="pd-qty-btn" id="pdQtyMinus" type="button">−</button>
                    <input  class="pd-qty-num" id="pdQty" type="number" value="1" min="1" />
                    <button class="pd-qty-btn" id="pdQtyPlus"  type="button">+</button>
                </div>
            </div>

            <div class="pd-cta-row">
                <button class="btn-p pd-btn-cart" data-product-id="@Model.Id" onclick="addToCart(this)">Add To Cart</button>
                <button class="pd-btn-wish" id="pdWish" type="button" title="Wishlist">♡</button>
            </div>

            <div class="pd-trust">
                <span class="pd-trust-item"><span class="pd-trust-ico">🚚</span> Free shipping over $75</span>
                <span class="pd-trust-item"><span class="pd-trust-ico">🔄</span> 30-day returns</span>
                <span class="pd-trust-item"><span class="pd-trust-ico">🔒</span> Secure checkout</span>
            </div>

        </div>
    </div>

    @* ── Bottom: Specs + Reviews ── *@
    <div class="pd-bottom reveal">

        @* Specifications *@
        <div>
            <div class="pd-section-ttl">Specifications</div>
            <div class="pd-specs-table">
                <div class="pd-spec-row">
                    <span class="pd-spec-k">Product Name</span>
                    <span class="pd-spec-v">@Model.Name</span>
                </div>
                @if (Model.Category != null)
                {
                    <div class="pd-spec-row">
                        <span class="pd-spec-k">Category</span>
                        <span class="pd-spec-v">@Model.Category.Name</span>
                    </div>
                }
                <div class="pd-spec-row">
                    <span class="pd-spec-k">Price</span>
                    <span class="pd-spec-v">$@Model.Price.ToString("0.00")</span>
                </div>
                <div class="pd-spec-row">
                    <span class="pd-spec-k">SKU</span>
                    <span class="pd-spec-v">#@Model.Id.ToString("D6")</span>
                </div>
                <div class="pd-spec-row">
                    <span class="pd-spec-k">Reviews</span>
                    <span class="pd-spec-v">@reviewCount review@(reviewCount == 1 ? "" : "s")</span>
                </div>
            </div>
        </div>

        @* ══════════════════════════════════
             REVIEWS SECTION
        ══════════════════════════════════ *@
        <div>
            <div class="pd-section-ttl">
                Customer Reviews
                @if (reviewCount > 0)
                {
                    <span style="font-family:var(--body);font-size:13px;color:var(--accent);margin-left:10px;letter-spacing:1px;">
                        (@reviewCount)
                    </span>
                }
            </div>

            @* ── TempData Alerts ── *@
            @if (TempData["success"] != null)
            {
                <div class="rv-alert rv-alert-success">✓ @TempData["success"]</div>
            }
            @if (TempData["error"] != null)
            {
                <div class="rv-alert rv-alert-error">✕ @TempData["error"]</div>
            }
            @if (TempData["info"] != null)
            {
                <div class="rv-alert rv-alert-info">ℹ @TempData["info"]</div>
            }

            @* ── Review List ── *@
            <div class="pd-reviews">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var rv in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        bool isOwner = rv.UserId == currentUserId;
                        bool isAdmin = User.IsInRole("Admin");

                        <div class="pd-review-card">
                            <div class="pdr-head">
                                <div>
                                    <div class="pdr-author">
                                        @(rv.User?.FullName ?? rv.User?.UserName ?? "Anonymous")
                                        @if (isOwner)
                                        {
                                            <span class="rv-you-badge">You</span>
                                        }
                                    </div>
                                    <div class="pdr-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            @(i <= rv.Rating ? "★" : "☆")
                                        }
                                    </div>
                                </div>
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span class="pdr-date">@rv.CreatedAt.ToString("MMM dd, yyyy")</span>

                                    @* Delete button — visible to review owner or Admin *@
                                    @if (isOwner || isAdmin)
                                    {
                                        <form asp-controller="Reviews" asp-action="Delete"
                                              method="post" style="margin:0;"
                                              onsubmit="return confirm('Delete this review?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@rv.Id" />
                                            <button type="submit" class="rv-delete-btn" title="Delete review">✕</button>
                                        </form>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(rv.comment))
                            {
                                <p class="pdr-text">@rv.comment</p>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="pd-review-card" style="text-align:center;padding:40px;">
                        <div style="font-size:40px;margin-bottom:12px;opacity:.4;">💬</div>
                        <div class="pdr-author" style="color:var(--text-dim);">No reviews yet</div>
                        <p class="pdr-text" style="margin-top:6px;">Be the first to review this product.</p>
                    </div>
                }
            </div>

            @* ── Write a Review Form ── *@
            @if (SignInManager.IsSignedIn(User))
            {
                @if (alreadyReviewed)
                {
                    <div class="rv-already-msg">
                        ✓ You've already reviewed this product.
                    </div>
                }
                else
                {
                    <div class="rv-form-wrap">
                        <div class="pd-section-ttl" style="font-size:16px;margin-bottom:20px;">Write a Review</div>

                        <form asp-controller="Reviews" asp-action="Submit" method="post" id="reviewForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />

                            @* Star Rating Picker *@
                            <div class="rv-field">
                                <label class="rv-label">Your Rating <span class="rv-req">*</span></label>
                                <div class="rv-star-picker" id="starPicker">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="rv-star-pick" data-val="@i">★</span>
                                    }
                                </div>
                                <input type="hidden" name="rating" id="ratingInput" value="0" />
                                <span class="rv-star-hint" id="starHint">Click to rate</span>
                            </div>

                            @* Comment *@
                            <div class="rv-field">
                                <label class="rv-label" for="rvComment">Your Review <span class="rv-req">*</span></label>
                                <textarea id="rvComment" name="comment" class="rv-textarea"
                                          placeholder="Share your thoughts about this product…"
                                          maxlength="1000" rows="4"></textarea>
                                <span class="rv-char-count"><span id="rvCharCount">0</span>/1000</span>
                            </div>

                            <button type="submit" class="btn-p rv-submit-btn" id="rvSubmit">
                                Submit Review
                            </button>
                        </form>
                    </div>
                }
            }
            else
            {
                <div class="rv-login-prompt">
                    <span>Want to share your experience?</span>
                    <a asp-area="Identity" asp-page="/Account/Login"
                       asp-route-returnUrl="@Context.Request.Path">Sign in to write a review</a>
                </div>
            }

        </div>
    </div>

    @* ── Related Products ── *@
    @if (related != null && related.Any())
    {
        <div class="pd-related reveal">
            <div class="sec-hd" style="margin-bottom:0;">
                <div>
                    <p class="sec-eye">From the same category</p>
                    <h2 class="sec-ttl">RELATED<br />PRODUCTS</h2>
                </div>
                <a asp-action="Index" class="sec-more">All Products →</a>
            </div>
            <div class="pd-related-grid">
                @foreach (var rp in related)
                {
                    int rpReviews = rp.Reviews?.Count ?? 0;
                    <div class="pag-card">
                        <div class="pag-thumb">
                            @if (!string.IsNullOrEmpty(rp.Img))
                            {
                                <img src="@rp.Img" alt="@rp.Name" class="pag-thumb-img" />
                            }
                            else
                            {
                                <span class="pag-thumb-emoji">🛍️</span>
                            }
                            @if (rpReviews > 0)
                            {
                                <span class="pag-badge badge-new">@rpReviews ★</span>
                            }
                        </div>
                        <div class="pag-body">
                            @if (rp.Category != null)
                            {
                                <div class="pag-cat">@rp.Category.Name</div>
                            }
                            <div class="pag-name">@rp.Name</div>
                            <div class="pag-foot">
                                <span class="pag-price">$@rp.Price.ToString("0.00")</span>
                            </div>
                        </div>
                        <div class="pag-actions">
                            <a asp-action="Details" asp-route-id="@rp.Id" class="pag-btn pag-btn-primary">View →</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

</div>

@section Scripts {
    <script src="~/js/products-details.js" asp-append-version="true"></script>
    <script src="~/js/Cart.js" asp-append-version="true"></script>
    <script>
        // ── Interactive Star Picker ──
        const stars   = document.querySelectorAll('.rv-star-pick');
        const input   = document.getElementById('ratingInput');
        const hint    = document.getElementById('starHint');
        const labels  = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];

        stars.forEach(star => {
            star.addEventListener('mouseenter', () => {
                const val = +star.dataset.val;
                stars.forEach(s => s.classList.toggle('hovered', +s.dataset.val <= val));
                hint.textContent = labels[val];
            });
            star.addEventListener('mouseleave', () => {
                const cur = +input.value;
                stars.forEach(s => s.classList.toggle('hovered', false));
                hint.textContent = cur > 0 ? labels[cur] : 'Click to rate';
            });
            star.addEventListener('click', () => {
                const val = +star.dataset.val;
                input.value = val;
                stars.forEach(s => s.classList.toggle('selected', +s.dataset.val <= val));
                hint.textContent = labels[val];
            });
        });

        // ── Character counter ──
        const textarea = document.getElementById('rvComment');
        const counter  = document.getElementById('rvCharCount');
        if (textarea) {
            textarea.addEventListener('input', () => {
                counter.textContent = textarea.value.length;
            });
        }

        // ── Validate rating before submit ──
        const form = document.getElementById('reviewForm');
        if (form) {
            form.addEventListener('submit', e => {
                if (+input.value === 0) {
                    e.preventDefault();
                    hint.textContent = 'Please select a rating!';
                    hint.style.color = 'var(--accent)';
                }
            });
        }
    </script>
}
