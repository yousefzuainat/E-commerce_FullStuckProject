@model ecommerce_system.Models.Proudect
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ecommerce_system.Models.AppliactionUser> SignInManager
@inject UserManager<ecommerce_system.Models.AppliactionUser> UserManager

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";

    int reviewCount = Model.Reviews?.Count ?? 0;
    double avgRating = reviewCount > 0 ? Model.Reviews!.Average(r => r.Rating) : 0;

    var related = Model.Category?.Proudects?
        .Where(p => p.Id != Model.Id)
        .Take(4)
        .ToList();

    var currentUserId = UserManager.GetUserId(User);
    bool alreadyReviewed = Model.Reviews?.Any(r => r.UserId == currentUserId) ?? false;
    var myReview = Model.Reviews?.FirstOrDefault(r => r.UserId == currentUserId);

    var firstImgUrl = Model.Images != null && Model.Images.Any()
        ? Model.Images.First().ImageUrl
        : Model.Img;
    bool hasImages = Model.Images != null && Model.Images.Any();

    // Discount
    var discount = Model.Discounts?.Select(d => d.DiscountPercent).DefaultIfEmpty(0m).Max() ?? 0m;
    var finalPrice = Model.Price * (1 - discount / 100m);
}

@section Styles {
    <link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/gallery.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/review-toast-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/DETAILS.css" asp-append-version="true" />
    
}

<div style="padding:25px;"></div>

@* ── Toast ── *@
@if (TempData["success"] != null || TempData["error"] != null || TempData["info"] != null)
{
    var toastType = TempData["success"] != null ? "success"
                  : TempData["error"] != null ? "error"
                  : "info";
    var toastMsg = (TempData["success"] ?? TempData["error"] ?? TempData["info"])?.ToString();
    var toastIcon = toastType == "success" ? "✓" : toastType == "error" ? "✕" : "ℹ";

    <div class="vx-toast vx-toast-@toastType" id="vxToast">
        <span class="vx-toast-icon">@toastIcon</span>
        <span class="vx-toast-msg">toastMsg</span>
        <button class="vx-toast-close" onclick="document.getElementById('vxToast').classList.add('vx-toast-hide')">✕</button>
    </div>
}

@* ── JS-driven toast (for AJAX actions like wishlist) ── *@
<div class="vx-toast" id="vxToastAjax" style="display:none;">
    <span class="vx-toast-icon" id="vxToastAjaxIcon">✓</span>
    <span class="vx-toast-msg" id="vxToastAjaxMsg"></span>
    <button class="vx-toast-close" onclick="hideAjaxToast()">✕</button>
</div>

@* ── Edit Review Modal ── *@
@if (myReview != null)
{
    <div class="vx-modal-backdrop" id="editModalBackdrop" onclick="closeEditModal()"></div>
    <div class="vx-modal" id="editModal" role="dialog" aria-modal="true" aria-label="Edit your review">
        <div class="vx-modal-head">
            <h3 class="vx-modal-ttl">Edit Your Review</h3>
            <button class="vx-modal-cls" onclick="closeEditModal()" aria-label="Close">✕</button>
        </div>
        <form asp-controller="Reviews" asp-action="Edit" method="post" id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@myReview.Id" />
            <div class="rv-field">
                <label class="rv-label">Rating <span class="rv-req">*</span></label>
                <div class="rv-star-picker" id="editStarPicker">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="rv-star-pick @(i <= myReview.Rating ? "selected" : "")"
                              data-val="@i">★</span>
                    }
                </div>
                <input type="hidden" name="rating" id="editRatingInput" value="@myReview.Rating" />
                <span class="rv-star-hint" id="editStarHint">@(new[] { "", "Poor", "Fair", "Good", "Very Good", "Excellent" }[myReview.Rating])</span>
            </div>
            <div class="rv-field">
                <label class="rv-label" for="editComment">Your Review <span class="rv-req">*</span></label>
                <textarea id="editComment" name="comment" class="rv-textarea"
                          maxlength="1000" rows="4">@myReview.comment</textarea>
                <span class="rv-char-count"><span id="editCharCount">@myReview.comment?.Length</span>/1000</span>
            </div>
            <div class="vx-modal-foot">
                <button type="button" class="btn-g" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="btn-p">Save Changes</button>
            </div>
        </form>
    </div>
}

<div class="det-page">

    @* ── Main layout ── *@
    <div class="det-layout reveal">

        @* ════════ GALLERY ════════ *@
        <div class="det-gallery">
            <div class="det-main-img" id="pdMainMedia">
                @if (!string.IsNullOrEmpty(firstImgUrl))
                {
                    <img id="pdMainImg" src="@firstImgUrl" alt="@Model.Name" />
                }
                else
                {
                    <span class="det-main-emoji">🛍️</span>
                }
                @if (discount > 0)
                {
                    <span class="det-img-badge">@discount.ToString("0")% OFF</span>
                }
            </div>

            @* Thumbnails *@
            @if (hasImages)
            {
                <div class="det-thumbs">
                    @{
                        int thumbIdx = 0;
                    }
                    @foreach (var img in Model.Images!)
                    {
                        <button type="button"
                                class="det-thumb-item @(thumbIdx == 0 ? "active" : "")"
                                onclick="pdSwitchImg(this, '@img.ImageUrl')">
                            <img src="@img.ImageUrl" alt="View @(thumbIdx + 1)" />
                        </button>
                        thumbIdx++;
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.Img))
            {
                <div class="det-thumbs">
                    <button type="button" class="det-thumb-item active" onclick="pdSwitchImg(this, '@Model.Img')">
                        <img src="@Model.Img" alt="@Model.Name" />
                    </button>
                </div>
            }
        </div>

        @* ════════ INFO ════════ *@
        <div class="det-info">

            @* Eyebrow *@
            <div class="det-eyebrow">
                @if (Model.Category != null)
                {
                    <span class="det-cat-tag">@Model.Category.Name</span>
                }
                <span class="det-stock-badge">
                    <span class="det-stock-dot"></span>
                    In Stock
                </span>
            </div>

            @* Name *@
            <h1 class="det-name">@Model.Name</h1>

            @* Rating row *@
            <div class="det-rating-row">
                @if (reviewCount > 0)
                {
                    <span class="det-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= Math.Round(avgRating) ? "" : "dim")">★</span>
                        }
                    </span>
                    <span class="det-rating-num">@avgRating.ToString("0.0")</span>
                    <span class="det-rating-count">(@reviewCount review@(reviewCount == 1 ? "" : "s"))</span>
                }
                else
                {
                    <span class="det-no-reviews">No reviews yet — be the first!</span>
                }
            </div>

            @* Price *@
            <div class="det-price-block">
                <span class="det-price">@finalPrice.ToString("C")</span>
                @if (discount > 0)
                {
                    <span class="det-price-old">@Model.Price.ToString("C")</span>
                    <span class="det-price-savings">Save @discount.ToString("0")%</span>
                }
            </div>

            @* Description *@
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="det-desc">@Model.Description</p>
            }

            @* Specs mini *@
            <div class="det-specs-mini">
                <div class="det-spec-item">
                    <span class="det-spec-lbl">SKU</span>
                    <span class="det-spec-val">#@Model.Id.ToString("D6")</span>
                </div>
                @if (Model.Category != null)
                {
                    <div class="det-spec-item">
                        <span class="det-spec-lbl">Category</span>
                        <span class="det-spec-val">@Model.Category.Name</span>
                    </div>
                }
                <div class="det-spec-item">
                    <span class="det-spec-lbl">Reviews</span>
                    <span class="det-spec-val">@reviewCount</span>
                </div>
                <div class="det-spec-item">
                    <span class="det-spec-lbl">Rating</span>
                    <span class="det-spec-val">@(reviewCount > 0 ? avgRating.ToString("0.0") + " / 5" : "—")</span>
                </div>
            </div>

            @* Quantity *@
            <div class="det-qty-row">
                <span class="det-qty-label">Qty</span>
                <div class="det-qty-ctrl">
                    <button class="det-qty-btn" id="pdQtyMinus" type="button">−</button>
                    <input class="det-qty-num" id="pdQty" type="number" value="1" min="1" />
                    <button class="det-qty-btn" id="pdQtyPlus" type="button">+</button>
                </div>
            </div>

            @* CTA row *@
            <div class="det-cta-row">
                <button class="det-btn-cart btn-p"
                        data-product-id="@Model.Id"
                        onclick="addToCart(this)">
                    Add To Cart
                </button>

                <form asp-action="AddToWishlist" asp-controller="WishListItems" method="post"
                      class="det-wish-form" id="wishlistForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="det-btn-wish" id="wishlistBtn" title="Add to Wishlist">♥</button>
                </form>
            </div>

            @* Trust strip *@
            <div class="det-trust">
                <div class="det-trust-item">
                    <span class="det-trust-ico">🚚</span>
                    <span><strong>Free shipping</strong> on orders over $75</span>
                </div>
                <div class="det-trust-item">
                    <span class="det-trust-ico">🔄</span>
                    <span><strong>30-day returns</strong> — no questions asked</span>
                </div>
                <div class="det-trust-item">
                    <span class="det-trust-ico">🔒</span>
                    <span><strong>Secure checkout</strong> — 256-bit SSL encryption</span>
                </div>
            </div>

        </div>
    </div>

    @* ════════════════════════════════════════
       BOTTOM: Specs | Reviews
    ═════════════════════════════════════════ *@
    <div class="det-bottom reveal">

        @* ── Specs ── *@
        <div>
            <div class="det-section-ttl">Specifications</div>
            <div class="det-specs-table">
                <div class="det-spec-row">
                    <span class="det-spec-k">Product Name</span>
                    <span class="det-spec-v">@Model.Name</span>
                </div>
                @if (Model.Category != null)
                {
                    <div class="det-spec-row">
                        <span class="det-spec-k">Category</span>
                        <span class="det-spec-v">@Model.Category.Name</span>
                    </div>
                }
                <div class="det-spec-row">
                    <span class="det-spec-k">Price</span>
                    <span class="det-spec-v">@finalPrice.ToString("C")</span>
                </div>
                @if (discount > 0)
                {
                    <div class="det-spec-row">
                        <span class="det-spec-k">Original Price</span>
                        <span class="det-spec-v" style="text-decoration:line-through;color:var(--muted);">@Model.Price.ToString("C")</span>
                    </div>
                    <div class="det-spec-row">
                        <span class="det-spec-k">Discount</span>
                        <span class="det-spec-v" style="color:#22c55e;">@discount.ToString("0")% OFF</span>
                    </div>
                }
                <div class="det-spec-row">
                    <span class="det-spec-k">SKU</span>
                    <span class="det-spec-v">#@Model.Id.ToString("D6")</span>
                </div>
                <div class="det-spec-row">
                    <span class="det-spec-k">Reviews</span>
                    <span class="det-spec-v">@reviewCount review@(reviewCount == 1 ? "" : "s")</span>
                </div>
                <div class="det-spec-row">
                    <span class="det-spec-k">Avg Rating</span>
                    <span class="det-spec-v">@(reviewCount > 0 ? avgRating.ToString("0.0") + " / 5" : "No ratings yet")</span>
                </div>
            </div>
        </div>

        @* ── Reviews ── *@
        <div>
            <div class="det-section-ttl">
                Customer Reviews
                @if (reviewCount > 0)
                {
                    <span class="det-section-count">@reviewCount</span>
                }
            </div>

            @* Rating summary with bar chart *@
            @if (reviewCount > 0)
            {
                <div class="det-rating-summary">
                    <div class="det-rating-big">
                        <div class="det-rating-big-num">@avgRating.ToString("0.0")</div>
                        <div class="det-rating-big-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                @(i <= Math.Round(avgRating) ? "★" : "☆")
                            }
                        </div>
                        <div class="det-rating-big-count">@reviewCount review@(reviewCount == 1 ? "" : "s")</div>
                    </div>
                    <div class="det-rating-bars">
                        @for (int star = 5; star >= 1; star--)
                        {
                            int cnt = Model.Reviews!.Count(r => r.Rating == star);
                            int pct = reviewCount > 0 ? (int)Math.Round(cnt * 100.0 / reviewCount) : 0;
                            <div class="det-bar-row">
                                <span>@star★</span>
                                <div class="det-bar-track">
                                    <div class="det-bar-fill" style="width:@pct%"></div>
                                </div>
                                <span class="det-bar-cnt">@cnt</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @* Review list *@
            <div class="det-reviews">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var rv in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        bool isOwner = rv.UserId == currentUserId;
                        bool isAdmin = User.IsInRole("Admin");

                        <div class="det-review-card">
                            <div class="det-rev-head">
                                <div>
                                    <div class="det-rev-author">
                                        @(rv.User?.FullName ?? rv.User?.UserName ?? "Anonymous")
                                        @if (isOwner)
                                        {
                                            <span class="det-rev-you">You</span>
                                        }
                                    </div>
                                    <div class="det-rev-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span class="@(i <= rv.Rating ? "" : "dim")">★</span>
                                        }
                                    </div>
                                </div>
                                <div class="det-rev-meta">
                                    <span class="det-rev-date">@rv.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    @if (isOwner)
                                    {
                                        <button type="button" class="det-rev-edit-btn"
                                                onclick="openEditModal()" title="Edit review">
                                            ✎
                                        </button>
                                    }
                                    @if (isOwner || isAdmin)
                                    {
                                        <form asp-controller="Reviews" asp-action="Delete" method="post" style="margin:0;"
                                              onsubmit="return confirm('Delete this review?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@rv.Id" />
                                            <button type="submit" class="det-rev-del-btn" title="Delete">✕</button>
                                        </form>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(rv.comment))
                            {
                                <p class="det-rev-text">@rv.comment</p>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="det-reviews-empty">
                        <div class="det-reviews-empty-ico">💬</div>
                        <div style="font-weight:600;margin-bottom:4px;">No reviews yet</div>
                        <div style="font-size:0.8rem;">Be the first to share your experience.</div>
                    </div>
                }
            </div>

            @* Write / already reviewed / login prompt *@
            @if (SignInManager.IsSignedIn(User))
            {
                @if (alreadyReviewed)
                {
                    <div class="det-already-msg">
                        <span>✓ You've reviewed this product.</span>
                        <button type="button" class="det-already-edit" onclick="openEditModal()">
                            Edit your review →
                        </button>
                    </div>
                }
                else
                {
                    <div class="det-rv-form-wrap">
                        <div class="det-rv-form-ttl">Write a Review</div>
                        <p class="det-rv-notice">You can submit one review per product.</p>

                        <form asp-controller="Reviews" asp-action="Submit" method="post" id="reviewForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />

                            <div class="rv-field">
                                <label class="rv-label">Your Rating <span class="rv-req">*</span></label>
                                <div class="rv-star-picker" id="starPicker">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="rv-star-pick" data-val="@i">★</span>
                                    }
                                </div>
                                <input type="hidden" name="rating" id="ratingInput" value="0" />
                                <span class="rv-star-hint" id="starHint">Click to rate</span>
                            </div>

                            <div class="rv-field">
                                <label class="rv-label" for="rvComment">Your Review <span class="rv-req">*</span></label>
                                <textarea id="rvComment" name="comment" class="rv-textarea"
                                          placeholder="Share your thoughts about this product…"
                                          maxlength="1000" rows="4"></textarea>
                                <span class="rv-char-count"><span id="rvCharCount">0</span>/1000</span>
                            </div>

                            <button type="submit" class="btn-p rv-submit-btn" id="rvSubmit">
                                Submit Review
                            </button>
                        </form>
                    </div>
                }
            }
            else
            {
                <div class="det-rv-login-prompt">
                    <span>Want to share your experience?</span>
                    <a asp-area="Identity" asp-page="/Account/Login"
                       asp-route-returnUrl="@Context.Request.Path">
                        Sign in to write a review →
                    </a>
                </div>
            }
        </div>
    </div>

    @* ── Related Products ── *@
    @if (related != null && related.Any())
    {
        <div class="det-related reveal">
            <div class="sec-hd">
                <div>
                    <p class="sec-eye">From the same category</p>
                    <h2 class="sec-ttl">RELATED<br />PRODUCTS</h2>
                </div>
                <a asp-action="Index" class="sec-more">All Products →</a>
            </div>
            <div class="det-related-grid">
                @foreach (var rp in related)
                {
                    @await Html.PartialAsync("_ProductCard", rp)
                }
            </div>
        </div>
    }

</div>

@section Scripts {
    <script src="~/js/products-details.js" asp-append-version="true"></script>
    <script src="~/js/Cart.js" asp-append-version="true"></script>
    <script>
        /* ── Toast auto-dismiss ── */
        const toast = document.getElementById('vxToast');
        if (toast) setTimeout(() => toast.classList.add('vx-toast-hide'), 4000);

        /* ── Image switcher ── */
        function pdSwitchImg(btn, src) {
        const img = document.getElementById('pdMainImg');
        if (img) {
        img.classList.add('pd-img-fade');
        setTimeout(() => { img.src = src; img.classList.remove('pd-img-fade'); }, 150);
        }
        document.querySelectorAll('.det-thumb-item').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        }

        /* ── Edit modal ── */
        function openEditModal() {
        document.getElementById('editModal')?.classList.add('open');
        document.getElementById('editModalBackdrop')?.classList.add('open');
        document.body.style.overflow = 'hidden';
        }
        function closeEditModal() {
        document.getElementById('editModal')?.classList.remove('open');
        document.getElementById('editModalBackdrop')?.classList.remove('open');
        document.body.style.overflow = '';
        }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeEditModal(); });

        /* ── Star pickers ── */
        const labels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];

        function initStarPicker(pickerId, inputId, hintId) {
        const stars = document.querySelectorAll(`#${pickerId} .rv-star-pick`);
        const input = document.getElementById(inputId);
        const hint  = document.getElementById(hintId);
        if (!stars.length) return;

        stars.forEach(star => {
        star.addEventListener('mouseenter', () => {
        const v = +star.dataset.val;
        stars.forEach(s => s.classList.toggle('hovered', +s.dataset.val <= v));
        if (hint) hint.textContent = labels[v];
        });
        star.addEventListener('mouseleave', () => {
        stars.forEach(s => s.classList.remove('hovered'));
        if (hint) hint.textContent = labels[+input.value] || 'Click to rate';
        });
        star.addEventListener('click', () => {
        const v = +star.dataset.val;
        input.value = v;
        stars.forEach(s => s.classList.toggle('selected', +s.dataset.val <= v));
        if (hint) hint.textContent = labels[v];
        });
        });
        }

        initStarPicker('starPicker',     'ratingInput',     'starHint');
        initStarPicker('editStarPicker', 'editRatingInput', 'editStarHint');

        /* ── Char counters ── */
        function initCharCounter(textareaId, counterId) {
        const ta  = document.getElementById(textareaId);
        const cnt = document.getElementById(counterId);
        if (ta && cnt) ta.addEventListener('input', () => cnt.textContent = ta.value.length);
        }
        initCharCounter('rvComment',   'rvCharCount');
        initCharCounter('editComment', 'editCharCount');

        /* ── Validate rating before submit ── */
        const reviewForm = document.getElementById('reviewForm');
        if (reviewForm) {
        reviewForm.addEventListener('submit', e => {
        const inp  = document.getElementById('ratingInput');
        const hint = document.getElementById('starHint');
        if (+inp.value === 0) {
        e.preventDefault();
        hint.textContent = 'Please select a rating!';
        hint.style.color = 'var(--accent)';
        }
        });
        }

        /* ── Qty buttons ── */
        const qtyInput = document.getElementById('pdQty');
        document.getElementById('pdQtyMinus')?.addEventListener('click', () => {
        if (qtyInput && +qtyInput.value > 1) qtyInput.value = +qtyInput.value - 1;
        });
        document.getElementById('pdQtyPlus')?.addEventListener('click', () => {
        if (qtyInput) qtyInput.value = +qtyInput.value + 1;
        });

        /* ── Animate rating bars on load ── */
        document.querySelectorAll('.det-bar-fill').forEach(bar => {
        const target = bar.style.width;
        bar.style.width = '0';
        setTimeout(() => bar.style.width = target, 300);
        });

        /* ── Wishlist AJAX ── */
function showAjaxToast(msg, type) {
    const toast = document.getElementById('vxToastAjax');
    const icon  = document.getElementById('vxToastAjaxIcon');
    const msgEl = document.getElementById('vxToastAjaxMsg');
    if (!toast) return;

    icon.textContent  = type === 'success' ? '✓' : type === 'error' ? '✕' : 'ℹ';
    msgEl.textContent = msg;

    toast.className = `vx-toast vx-toast-${type}`;
    toast.style.display = '';
    toast.classList.remove('vx-toast-hide');

    clearTimeout(toast._timer);
    toast._timer = setTimeout(() => toast.classList.add('vx-toast-hide'), 4000);
}

function hideAjaxToast() {
    document.getElementById('vxToastAjax')?.classList.add('vx-toast-hide');
}

document.getElementById('wishlistForm')?.addEventListener('submit', async function (e) {
    e.preventDefault();

    const btn  = document.getElementById('wishlistBtn');
    const data = new FormData(this);

    btn.disabled = true;

    try {
        const res = await fetch(this.action, {
            method: 'POST',
            body: data,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });

        if (res.ok) {
            btn.textContent = '♥';
            btn.style.color = 'var(--accent)';
            showAjaxToast('Added to your wishlist!', 'success');
        } else if (res.status === 401) {
            showAjaxToast('Please sign in to save items.', 'info');
        } else {
            showAjaxToast('Already in your wishlist.', 'info');
        }
    } catch {
        showAjaxToast('Something went wrong. Try again.', 'error');
    } finally {
        btn.disabled = false;
    }
});
    </script>
}
