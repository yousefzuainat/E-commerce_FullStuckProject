@model ecommerce_system.Models.Proudect
@{
    ViewData["Title"] = "Details";
}

<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nexus Commerce - @Model?.Name</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "on-primary-fixed-variant": "#004395",
        "tertiary": "#ffb3ad",
        "surface-bright": "#333a44",
        "background": "#0d141d",
        "inverse-on-surface": "#2a313b",
        "secondary-fixed": "#6ffbbe",
        "on-error": "#690005",
        "secondary": "#4edea3",
        "secondary-fixed-dim": "#4edea3",
        "primary-fixed": "#d8e2ff",
        "on-surface-variant": "#c2c6d6",
        "surface-variant": "#2e353f",
        "on-surface": "#dce3f0",
        "on-error-container": "#ffdad6",
        "error-container": "#93000a",
        "on-secondary": "#003824",
        "inverse-surface": "#dce3f0",
        "surface-container-highest": "#2e353f",
        "on-primary-container": "#00285d",
        "secondary-container": "#00a572",
        "surface-container-high": "#232a34",
        "error": "#ffb4ab",
        "surface": "#0d141d",
        "primary-fixed-dim": "#adc6ff",
        "surface-container-low": "#151c25",
        "outline": "#8c909f",
        "tertiary-fixed-dim": "#ffb3ad",
        "primary-container": "#4d8eff",
        "on-secondary-container": "#00311f",
        "on-tertiary": "#68000a",
        "surface-container-lowest": "#080f17",
        "tertiary-fixed": "#ffdad7",
        "surface-container": "#192029",
        "inverse-primary": "#005ac2",
        "surface-dim": "#0d141d",
        "surface-tint": "#adc6ff",
        "primary": "#adc6ff",
        "tertiary-container": "#ff5451",
        "outline-variant": "#424754",
        "on-primary": "#002e6a",
        "on-background": "#dce3f0"
        },
        "borderRadius": {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px"
        },
        "spacing": {
        "stack-sm": "0.5rem",
        "container-max": "1440px",
        "gutter": "1.5rem",
        "stack-md": "1rem",
        "stack-lg": "2rem",
        "margin-x": "2rem"
        },
        "fontFamily": {
        "label-sm": ["Inter"],
        "body-lg": ["Inter"],
        "label-md": ["Inter"],
        "headline-sm": ["Inter"],
        "body-sm": ["Inter"],
        "body-md": ["Inter"],
        "headline-md": ["Inter"],
        "headline-lg": ["Inter"],
        "display-lg": ["Inter"]
        },
        "fontSize": {
        "label-sm": ["12px", { "lineHeight": "16px", "fontWeight": "600" }],
        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
        "label-md": ["14px", { "lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "500" }],
        "headline-sm": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }]
        }
        }
        }
        }
    </script>
</head>
<body class="bg-background text-on-background font-body-md antialiased flex">

    <!-- ===================== SIDE NAV BAR ===================== -->
    <aside class="fixed left-0 top-0 h-screen w-64 bg-surface-dim border-r border-outline-variant flex flex-col justify-between py-gutter hidden md:flex z-40">
        <div>
            <div class="px-6 mb-8 flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-secondary-container/20 flex items-center justify-center border border-secondary/30">
                    <span class="material-symbols-outlined text-secondary" style='font-variation-settings: "FILL" 1;'>storefront</span>
                </div>
                <div>
                    <h1 class="font-headline-sm text-headline-sm font-black text-secondary">Nexus Commerce</h1>
                    <p class="font-label-sm text-label-sm text-on-surface-variant">Enterprise Admin</p>
                </div>
            </div>
            <nav class="flex flex-col gap-1 px-2">
                <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="font-label-md text-label-md">Dashboard</span>
                </a>
                <a class="flex items-center gap-3 bg-secondary-container/20 text-secondary border-r-4 border-secondary px-4 py-3 rounded-lg" href="#">
                    <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>inventory_2</span>
                    <span class="font-label-md text-label-md font-bold">Inventory</span>
                </a>
                <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span class="font-label-md text-label-md">Orders</span>
                </a>
                <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                    <span class="material-symbols-outlined">group</span>
                    <span class="font-label-md text-label-md">Customers</span>
                </a>
                <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                    <span class="material-symbols-outlined">monitoring</span>
                    <span class="font-label-md text-label-md">Analytics</span>
                </a>
                <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                    <span class="material-symbols-outlined">campaign</span>
                    <span class="font-label-md text-label-md">Marketing</span>
                </a>
            </nav>
        </div>
        <div class="px-2">
            <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                <span class="material-symbols-outlined">settings</span>
                <span class="font-label-md text-label-md">Account Settings</span>
            </a>
            <a class="flex items-center gap-3 text-on-surface-variant px-4 py-3 rounded-lg hover:bg-surface-variant/50 transition-all duration-150" href="#">
                <span class="material-symbols-outlined">logout</span>
                <span class="font-label-md text-label-md">Sign Out</span>
            </a>
        </div>
    </aside>

    <!-- ===================== MAIN CONTENT ===================== -->
    <main class="flex-1 md:ml-64 flex flex-col min-h-screen">

        <!-- TOP NAV BAR -->
        <header class="sticky top-0 z-50 flex items-center justify-between px-gutter py-stack-sm w-full bg-surface-container/80 backdrop-blur-md border-b border-outline-variant hidden md:flex">
            <div class="flex items-center gap-4">
                <span class="font-headline-md text-headline-md font-bold text-primary">NexusAdmin</span>
            </div>
            <div class="flex-1 max-w-md mx-8">
                <div class="relative group">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors">search</span>
                    <input class="w-full bg-surface-variant border border-outline-variant rounded-lg py-2 pl-10 pr-4 text-on-surface font-body-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all bg-[#1f2937] border-[#374151]"
                           placeholder="Search inventory..." type="text" />
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button class="p-2 text-on-surface-variant hover:bg-surface-bright/10 rounded-full transition-colors duration-200">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <button class="p-2 text-on-surface-variant hover:bg-surface-bright/10 rounded-full transition-colors duration-200">
                    <span class="material-symbols-outlined">help</span>
                </button>
                <button class="p-2 text-on-surface-variant hover:bg-surface-bright/10 rounded-full transition-colors duration-200">
                    <span class="material-symbols-outlined">settings</span>
                </button>
            </div>
        </header>

        <!-- ===================== PRODUCT DETAILS CONTENT ===================== -->
        <div class="p-gutter max-w-container-max mx-auto w-full flex-1">

            <!-- BREADCRUMBS -->
            <nav class="flex items-center gap-2 text-on-surface-variant font-label-sm text-label-sm mb-6">
                <a class="hover:text-primary transition-colors" asp-action="Index">Inventory</a>
                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                @if (Model?.Category != null)
                {
                    <a class="hover:text-primary transition-colors" href="#">@Html.DisplayFor(model => model.Category.Name)</a>
                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                }
                <span class="text-on-surface">@Html.DisplayFor(model => model.Name)</span>
            </nav>

            <!-- MAIN GRID -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

                <!-- ========== LEFT COLUMN: IMAGE GALLERY ========== -->
                <div class="lg:col-span-7 space-y-4">
                    <div class="aspect-[4/3] rounded-xl overflow-hidden bg-[#1f2937] border border-[#374151] relative group">
                        @if (!string.IsNullOrEmpty(Model?.Img))
                        {
                            <img alt="@Model.Name"
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                 src="@Model.Img" />
                        }
                        else
                        {
                            <!-- Placeholder when no image is set -->
                            <div class="w-full h-full flex flex-col items-center justify-center text-on-surface-variant gap-3">
                                <span class="material-symbols-outlined text-6xl">image_not_supported</span>
                                <span class="font-label-md text-label-md">No Image Available</span>
                            </div>
                        }
                        <button class="absolute top-4 right-4 p-2 bg-surface-container/80 backdrop-blur-sm rounded-full text-on-surface hover:text-primary transition-colors border border-outline-variant">
                            <span class="material-symbols-outlined">zoom_in</span>
                        </button>
                    </div>
                </div>

                <!-- ========== RIGHT COLUMN: INFO & ACTIONS ========== -->
                <div class="lg:col-span-5 flex flex-col">

                    <!-- TITLE & BADGE -->
                    <div class="mb-2 flex items-start justify-between">
                        <div>
                            <div class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-secondary-container/20 text-secondary font-label-sm text-label-sm mb-3 border border-secondary/30">
                                In Stock
                            </div>
                            <h1 class="font-headline-lg text-headline-lg text-on-surface mb-2">
                                @Html.DisplayFor(model => model.Name)
                            </h1>
                            @if (Model?.Category != null)
                            {
                                <p class="font-body-lg text-body-lg text-on-surface-variant">
                                    @Html.DisplayFor(model => model.Category.Name)
                                </p>
                            }
                        </div>
                    </div>

                    <!-- PRICE -->
                    <div class="flex items-end gap-4 mb-6 pb-6 border-b border-[#374151]">
                        <span class="font-display-lg text-display-lg text-primary">
                            $@Html.DisplayFor(model => model.Price)
                        </span>
                        <!-- Static rating placeholder — replace with real data if available -->
                        <div class="flex items-center gap-2 mb-2">
                            <div class="flex text-tertiary">
                                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>star</span>
                                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>star</span>
                                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>star</span>
                                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>star</span>
                                <span class="material-symbols-outlined">star_half</span>
                            </div>
                            <span class="font-label-md text-label-md text-on-surface-variant">4.8 (124 Reviews)</span>
                        </div>
                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="flex gap-4 mb-8">
                        <button class="flex-1 bg-primary text-on-primary font-label-md text-label-md py-3 px-6 rounded-lg hover:shadow-[0_0_15px_rgba(77,142,255,0.2)] transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">shopping_cart</span>
                            Add to Cart
                        </button>
                        <a asp-action="Edit" asp-route-id="@Model?.Id"
                               class="bg-transparent border border-[#374151] text-on-surface-variant py-3 px-4 rounded-lg hover:bg-[#1f2937] transition-colors flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">edit</span>
                            Edit
                        </a>
                        <button class="bg-transparent border border-[#374151] text-on-surface-variant py-3 px-4 rounded-lg hover:bg-[#1f2937] transition-colors flex items-center justify-center">
                            <span class="material-symbols-outlined">favorite</span>
                        </button>
                    </div>

                    <!-- PRODUCT DESCRIPTION ACCORDION -->
                    <div class="bg-[#1f2937] border border-[#374151] rounded-xl overflow-hidden mb-6">
                        <div class="p-4 border-b border-[#374151] flex justify-between items-center cursor-pointer hover:bg-surface-variant/50 transition-colors"
                             onclick="this.nextElementSibling.classList.toggle('hidden')">
                            <h3 class="font-headline-sm text-headline-sm text-on-surface">Product Description</h3>
                            <span class="material-symbols-outlined text-on-surface-variant">expand_less</span>
                        </div>
                        <div class="p-4 bg-background/30 font-body-sm text-body-sm text-on-surface-variant leading-relaxed">
                            @Html.DisplayFor(model => model.Description)
                        </div>
                    </div>

                    <!-- PRODUCT META DETAILS -->
                    <div class="bg-[#1f2937] border border-[#374151] rounded-xl overflow-hidden">
                        <div class="p-4 border-b border-[#374151]">
                            <h3 class="font-headline-sm text-headline-sm text-on-surface">Product Details</h3>
                        </div>
                        <div class="p-4 space-y-3">
                            <div class="flex justify-between items-center py-2 border-b border-[#374151]/50">
                                <span class="font-label-md text-label-md text-on-surface-variant">
                                    @Html.DisplayNameFor(model => model.Name)
                                </span>
                                <span class="font-label-md text-label-md text-on-surface">
                                    @Html.DisplayFor(model => model.Name)
                                </span>
                            </div>
                            <div class="flex justify-between items-center py-2 border-b border-[#374151]/50">
                                <span class="font-label-md text-label-md text-on-surface-variant">
                                    @Html.DisplayNameFor(model => model.Price)
                                </span>
                                <span class="font-label-md text-label-md text-primary font-semibold">
                                    $@Html.DisplayFor(model => model.Price)
                                </span>
                            </div>
                            @if (Model?.Category != null)
                            {
                                <div class="flex justify-between items-center py-2">
                                    <span class="font-label-md text-label-md text-on-surface-variant">
                                        @Html.DisplayNameFor(model => model.Category)
                                    </span>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-primary/10 text-primary font-label-sm text-label-sm border border-primary/20">
                                        @Html.DisplayFor(model => model.Category.Name)
                                    </span>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>

            <!-- ========== BOTTOM SECTION ========== -->
            <div class="grid grid-cols-1 gap-8 mt-12">
                <div class="bg-[#1f2937] border border-[#374151] rounded-xl p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">forum</span>
                            Recent Reviews
                        </h3>
                        <a class="font-label-sm text-label-sm text-primary hover:underline" href="#">View All</a>
                    </div>
                    <div class="space-y-4">
                        <!-- Review Item 1 -->
                        <div class="p-4 bg-background/30 rounded-lg border border-[#374151]">
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center font-label-sm text-on-surface">AM</div>
                                    <div>
                                        <span class="font-label-sm text-label-sm text-on-surface block">Alex M.</span>
                                        <span class="font-label-sm text-[10px] text-on-surface-variant">Verified Buyer</span>
                                    </div>
                                </div>
                                <div class="flex text-tertiary text-sm">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <span class="material-symbols-outlined text-[16px]" style='font-variation-settings: "FILL" 1;'>star</span>
                                    }
                                </div>
                            </div>
                            <p class="font-body-sm text-body-sm text-on-surface-variant">
                                "The build quality is exceptional. The tactile feedback combined with the acoustic foam makes typing incredibly satisfying. Worth every penny."
                            </p>
                        </div>
                        <!-- Review Item 2 -->
                        <div class="p-4 bg-background/30 rounded-lg border border-[#374151]">
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center font-label-sm text-on-surface">SJ</div>
                                    <div>
                                        <span class="font-label-sm text-label-sm text-on-surface block">Sarah J.</span>
                                        <span class="font-label-sm text-[10px] text-on-surface-variant">Verified Buyer</span>
                                    </div>
                                </div>
                                <div class="flex text-tertiary text-sm">
                                    @for (int i = 0; i < 4; i++)
                                    {
                                        <span class="material-symbols-outlined text-[16px]" style='font-variation-settings: "FILL" 1;'>star</span>
                                    }
                                    <span class="material-symbols-outlined text-[16px]">star_border</span>
                                </div>
                            </div>
                            <p class="font-body-sm text-body-sm text-on-surface-variant">
                                "Great product, the wireless connection is flawless. Only giving 4 stars because the configuration software took a bit to figure out."
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BACK TO LIST LINK -->
            <div class="mt-8 flex items-center gap-4">
                <a asp-action="Index"
                       class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label-md text-label-md">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back to List
                </a>
            </div>

        </div>
    </main>

    <script src="~/js/voltex.js"></script>
</body>
</html>
