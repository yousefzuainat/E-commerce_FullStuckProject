@model IEnumerable<ecommerce_system.Models.Proudect>

@{
    ViewData["Title"] = "Products List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
        <h1 class="text-3xl font-black text-white mb-2 tracking-tight">Products Inventory</h1>
        <p class="text-gray-400 font-medium">Manage and track your product stock levels.</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">search</span>
            <input type="text" id="prodSearch" placeholder="Search products..." 
                   class="bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-white placeholder-gray-500 w-full md:w-64 transition-all" />
        </div>
        <a asp-action="Create" class="inline-flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-5 py-2 rounded-xl font-bold transition-all shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined text-lg">add</span>
            Add Product
        </a>
    </div>
</div>

@if (ViewBag.FilteredCategory != null)
{
    <div class="mb-6 p-4 bg-primary/10 border border-primary/20 text-primary rounded-2xl flex justify-between items-center backdrop-blur-sm">
        <div class="flex items-center gap-2">
            <span class="material-symbols-outlined">filter_alt</span>
            <span class="font-medium">Showing products for category: <strong class="text-white">@ViewBag.FilteredCategory</strong></span>
        </div>
        <a asp-action="Index" class="text-sm font-bold underline hover:text-white transition">Clear Filter</a>
    </div>
}

<!-- TABLE CARD -->
<div class="glass-panel rounded-2xl overflow-hidden border border-white/5 shadow-2xl">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-white/5 text-gray-400 text-xs uppercase tracking-widest font-black border-b border-white/5">
                    <th class="px-6 py-5 font-bold">Product</th>
                    <th class="px-6 py-5 font-bold hidden lg:table-cell">Description</th>
                    <th class="px-6 py-5 font-bold">Price</th>
                    <th class="px-6 py-5 font-bold">Category</th>
                    <th class="px-6 py-5 font-bold text-right">Actions</th>
                </tr>
            </thead>
            <tbody id="prodTableBody" class="divide-y divide-white/5">
                @if (!Model.Any())
                {
                    <tr id="emptyRow">
                        <td colspan="5" class="px-6 py-20 text-center">
                            <div class="flex flex-col items-center justify-center gap-3 opacity-50">
                                <span class="material-symbols-outlined text-6xl">inventory_2</span>
                                <p class="font-medium">No products found in your inventory.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="prod-row hover:bg-white/[0.02] transition-colors group"
                            data-name="@item.Name.ToLower()">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-xl border border-white/10 bg-surface-container overflow-hidden flex items-center justify-center shrink-0">
                                        @if (!string.IsNullOrEmpty(item.Img))
                                        {
                                            <img src="@item.Img" alt="@item.Name" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-gray-600">image</span>
                                        }
                                    </div>
                                    <div>
                                        <div class="font-bold text-white group-hover:text-primary transition-colors">@item.Name</div>
                                        <div class="text-xs text-gray-500 font-medium">ID: #@item.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 hidden lg:table-cell">
                                <p class="text-sm text-gray-400 line-clamp-1 max-w-xs" title="@item.Description">
                                    @(string.IsNullOrEmpty(item.Description) ? "—" : item.Description)
                                </p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="font-black text-white">$@item.Price.ToString("0.00")</span>
                                    @{ var discount = item.Discounts?.FirstOrDefault(d => d.Active)?.DiscountPercent ?? 0; }
                                    @if(discount > 0)
                                    {
                                        <span class="text-[10px] font-bold text-red-400 uppercase tracking-tighter">-@discount% OFF</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/5 text-gray-300 rounded-lg text-xs font-bold border border-white/5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                                    @(item.Category?.Name ?? "Uncategorized")
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
                                    <a asp-action="Edit" asp-route-id="@item.Id" 
                                       class="w-9 h-9 rounded-xl bg-white/5 flex items-center justify-center hover:bg-primary hover:text-white transition-all border border-white/5" title="Edit">
                                        <span class="material-symbols-outlined text-lg">edit</span>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" 
                                       class="w-9 h-9 rounded-xl bg-white/5 flex items-center justify-center hover:bg-white/20 text-white transition-all border border-white/5" title="Details">
                                        <span class="material-symbols-outlined text-lg">visibility</span>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" 
                                       class="w-9 h-9 rounded-xl bg-white/5 flex items-center justify-center hover:bg-red-500/20 hover:text-red-500 transition-all border border-white/5" title="Delete">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div id="prodNoResults" class="hidden text-center py-20 glass-panel rounded-2xl mt-4 border border-white/5">
    <span class="material-symbols-outlined text-6xl mb-4 text-gray-600">search_off</span>
    <h3 class="text-xl font-bold text-white mb-1">No matching products</h3>
    <p class="text-gray-400">Try adjusting your search terms.</p>
</div>

@section Scripts {
    <script>
        document.getElementById('prodSearch')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.prod-row');
            let hasVisible = false;
            
            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                if (name.includes(searchTerm)) {
                    row.style.display = '';
                    hasVisible = true;
                } else {
                    row.style.display = 'none';
                }
            });
            
            const noResults = document.getElementById('prodNoResults');
            const emptyRow = document.getElementById('emptyRow');
            
            if (noResults) {
                if (!hasVisible && rows.length > 0) {
                    noResults.classList.remove('hidden');
                } else {
                    noResults.classList.add('hidden');
                }
            }
        });
    </script>
}