@model IEnumerable<ecommerce_system.Models.Proudect>

@{
    ViewData["Title"] = "All Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
}

@* ── Alerts ── *@
@if (TempData["success"] != null)
{
    <div class="tf-alert tf-alert-success reveal">✓ @TempData["success"]</div>
}

<div class="prod-page-bar reveal">
    <div class="prod-page-bar-inner">
        <div>
            <p class="sec-eye">Manage Store</p>
            <h1 class="sec-ttl">ALL<br />PRODUCTS</h1>
        </div>
    </div>
</div>

@* ── Synchronized Filter & Search Bar Zone ── *@
<div class="prod-filter-bar reveal">
    @* Search Input Wrapper targeting .prod-search-wrap *@
    <div class="prod-search-wrap">
        <span class="ps-icon">⌕</span>
        <input type="text" id="searchInput" placeholder="Search product names..." class="prod-search-input" />
    </div>

    @* Category Dropdown targeting .prod-select *@
    <select id="categoryFilter" class="prod-select">
        <option value="">All Categories</option>
        @if (Model.Any())
        {
            @foreach (var cat in Model.Where(p => p.Category != null).Select(p => p.Category!.Name).Distinct())
            {
                <option value="@cat.ToLower()">@cat</option>
            }
        }
    </select>

    @* Sorting Dropdown targeting .prod-select *@
    <select id="priceSort" class="prod-select">
        <option value="">Sort Products</option>
        <option value="price-asc">Price: Low to High</option>
        <option value="price-desc">Price: High to Low</option>
        <option value="name-asc">Name: A to Z</option>
    </select>
</div>

@if (ViewBag.CurrentSearch != null)
{
    <div class="search-center-wrapper">
        <div class="search-result-frame reveal">
            <div class="search-frame-content">
                <span class="search-frame-label">FILTER ACTIVE</span>
                <span class="search-frame-text">
                    Showing results for <strong class="search-frame-keyword">"@ViewBag.CurrentSearch"</strong>
                </span>
            </div>
            <a href="/Proudects" class="search-frame-clear" aria-label="Clear search">
                Clear <span class="clear-cross">✕</span>
            </a>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="prod-empty reveal">
        <div class="prod-empty-ico">📦</div>
        <div class="prod-empty-ttl">No products yet</div>
    </div>
}
else
{
    <div class="prod-admin-grid reveal" id="prodGrid">
        @foreach (var p in Model)
        {
            // Calculate Discount and Price Logic
            var discountPercent = p.Discounts?.Select(d => d.DiscountPercent).DefaultIfEmpty(0m).Max() ?? 0m;
            var finalPrice = p.Price * (1 - discountPercent / 100m);
            
            // Calculate Stars safely
            int totalReviews = p.Reviews?.Count ?? 0;
            double avgRating = totalReviews > 0 ? p.Reviews!.Average(r => r.Rating) : 0;
            int fullStars = (int)Math.Round(avgRating);
            
            <div class="pag-card" data-name="@p.Name.ToLower()" data-category="@(p.Category?.Name?.ToLower() ?? "")" data-price="@finalPrice.ToString("F2")">
                
                <a asp-action="Details" asp-route-id="@p.Id" class="prod-card-link">
                    <div class="pag-thumb">
                        @if (!string.IsNullOrEmpty(p.Img))
                        {
                            <img src="~@p.Img" alt="@p.Name" class="pag-thumb-img" asp-append-version="true" />
                        }
                        else
                        {
                            <span class="pag-thumb-emoji">🛍️</span>
                        }

                        @if (discountPercent > 0)
                        {
                            <span class="p-badge badge-sale">@discountPercent.ToString("0")% OFF</span>
                        }
                        else if (p.Id < 10)
                        {
                            <span class="p-badge badge-new">NEW</span>
                        }
                    </div>
                </a>
             
                <div class="pag-body">
                    <div class="pag-name">@p.Name</div>

                    @if (p.Category != null)
                    {
                        <div class="pag-cat">@p.Category.Name</div>
                    }
                    
                    <p class="p-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= fullStars)
                            {
                                <span style="color: #f5a623;">★</span>
                            }
                            else
                            {
                                <span style="color: #ccc;">★</span>
                            }
                        }
                        <span class="p-rc">(@totalReviews)</span>
                    </p>

                    @if (!string.IsNullOrEmpty(p.Description))
                    {
                        <div class="pag-desc-preview">@p.Description</div>
                    }
                        
                    <div class="pag-foot">
                        <div class="price-container">
                            <span class="pag-price">@finalPrice.ToString("C")</span>
                            @if (discountPercent > 0)
                            {
                                <span class="pag-old">@p.Price.ToString("C")</span>
                            }
                        </div>

                        @if (totalReviews > 0)
                        {
                            <span class="pag-review-pill">💬 @totalReviews</span>
                        }
                    </div>
                </div>
                
                <div class="pag-actions">
                    <form asp-action="AddToWishlist" asp-controller="WishListItems" method="post" class="action-form" data-ajax="true" style="flex:1;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@p.Id" />
                        <button type="submit" class="pag-btn pag-btn-ghost">
                            <span>♥</span> Wishlist
                        </button>
                    </form>
                    <button class="pag-btn pag-btn-danger" data-product-id="@p.Id" onclick="addToCart(this)" style="flex:1;">
                        <span>🛒</span> Cart
                    </button>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="~/js/products.js" asp-append-version="true"></script>
    <script src="~/js/Cart.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const searchInput = document.getElementById("searchInput");
            const categoryFilter = document.getElementById("categoryFilter");
            const priceSort = document.getElementById("priceSort");
            const grid = document.getElementById("prodGrid");

            if (!grid) return;

            function processFilters() {
                const query = searchInput.value.toLowerCase().trim();
                const targetCat = categoryFilter.value;
                const cards = Array.from(grid.querySelectorAll(".pag-card"));

                cards.forEach(card => {
                    const productName = card.getAttribute("data-name") || "";
                    const productCat = card.getAttribute("data-category") || "";
                    
                    const matchesSearch = productName.includes(query);
                    const matchesCategory = targetCat === "" || productCat === targetCat;

                    if (matchesSearch && matchesCategory) {
                        card.style.display = "";
                    } else {
                        card.style.display = "none";
                    }
                });

                // Handle Dynamic Client Sorting
                const sortMode = priceSort.value;
                if (sortMode) {
                    const structuralCards = Array.from(grid.querySelectorAll(".pag-card"));
                    
                    structuralCards.sort((rowA, rowB) => {
                        if (sortMode.startsWith("price")) {
                            const valA = parseFloat(rowA.getAttribute("data-price") || 0);
                            const valB = parseFloat(rowB.getAttribute("data-price") || 0);
                            return sortMode === "price-asc" ? valA - valB : valB - valA;
                        } else if (sortMode === "name-asc") {
                            const stringA = rowA.getAttribute("data-name") || "";
                            const stringB = rowB.getAttribute("data-name") || "";
                            return stringA.localeCompare(stringB);
                        }
                        return 0;
                    });

                    // Re-append items sequentially based on sort array layout
                    structuralCards.forEach(card => grid.appendChild(card));
                }
            }

            if (searchInput) searchInput.addEventListener("input", processFilters);
            if (categoryFilter) categoryFilter.addEventListener("change", processFilters);
            if (priceSort) priceSort.addEventListener("change", processFilters);
        });
    </script>
}