@model ecommerce_system.ViewModel.ProudectEditViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-5xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-white mb-2 tracking-tight">Edit Product</h1>
            <p class="text-gray-400 font-medium">Update the details for <span class="text-primary">@Model.Name</span>.</p>
        </div>
        <a asp-action="Index" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors font-medium">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to List
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ExistingImg" />

        <!-- Main Form Area -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information -->
            <div class="glass-panel rounded-2xl p-8 border border-white/5 shadow-xl">
                <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">info</span>
                    Basic Information
                </h3>
                
                <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm"></div>

                <div class="space-y-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-bold text-gray-300 mb-2">Product Name</label>
                        <input asp-for="Name" placeholder="Enter product name"
                               class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                        <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-bold text-gray-300 mb-2">Description</label>
                        <textarea asp-for="Description" placeholder="Enter product description"
                                  rows="6"
                                  class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all"></textarea>
                        <span asp-validation-for="Description" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>
                </div>
            </div>

            <!-- Pricing & Inventory -->
            <div class="glass-panel rounded-2xl p-8 border border-white/5 shadow-xl">
                <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">payments</span>
                    Pricing & Category
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Price" class="block text-sm font-bold text-gray-300 mb-2">Price</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
                            <input asp-for="Price" placeholder="0.00" type="number" step="0.01"
                                   class="w-full bg-white/5 border border-white/10 rounded-xl py-3 pl-8 pr-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                        </div>
                        <span asp-validation-for="Price" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>

                    <div>
                        <label asp-for="DiscountPercent" class="block text-sm font-bold text-gray-300 mb-2">Discount %</label>
                        <div class="relative">
                            <input asp-for="DiscountPercent" placeholder="0" type="number" min="0" max="100"
                                   class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">%</span>
                        </div>
                        <span asp-validation-for="DiscountPercent" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="CategoryId" class="block text-sm font-bold text-gray-300 mb-2">Category</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId"
                                class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all appearance-none">
                            <option value="">Select a category...</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Area -->
        <div class="space-y-6">
            <!-- Existing Images Gallery -->
            <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl">
                <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">photo_library</span>
                    Product Images
                    @if (Model.ExistingImages != null && Model.ExistingImages.Count > 0)
                    {
                        <span class="ml-auto text-xs bg-primary/20 text-primary px-2 py-1 rounded-full font-bold">@Model.ExistingImages.Count photo(s)</span>
                    }
                </h3>

                <div class="space-y-4">
                    @if (Model.ExistingImages != null && Model.ExistingImages.Count > 0)
                    {
                        <p class="text-xs text-gray-500 font-medium">Check images to <span class="text-red-400">delete</span> them:</p>
                        <div class="grid grid-cols-2 gap-3">
                            @foreach (var image in Model.ExistingImages)
                            {
                                <div class="relative group rounded-xl overflow-hidden border border-white/10 bg-white/5">
                                    <img src="@image.ImageUrl" alt="Product image" class="w-full aspect-square object-cover transition-transform group-hover:scale-105" />
                                    <!-- Delete checkbox overlay -->
                                    <label class="absolute inset-0 flex items-center justify-center cursor-pointer bg-black/0 group-hover:bg-black/40 transition-all">
                                        <input type="checkbox" name="ImagesToDelete" value="@image.Id"
                                               class="peer hidden" />
                                        <span class="peer-checked:opacity-100 opacity-0 group-hover:opacity-60 transition-all bg-red-600 rounded-full p-1">
                                            <span class="material-symbols-outlined text-white text-sm leading-none">delete</span>
                                        </span>
                                    </label>
                                    <!-- Always-visible delete badge when checked -->
                                    <label class="absolute top-2 right-2 cursor-pointer z-10">
                                        <input type="checkbox" name="ImagesToDelete" value="@image.Id"
                                               id="del_@image.Id"
                                               class="peer sr-only"
                                               onchange="toggleDeleteMark(this)" />
                                        <span class="w-7 h-7 rounded-full bg-black/60 border border-white/20 flex items-center justify-center peer-checked:bg-red-600 peer-checked:border-red-500 transition-all">
                                            <span class="material-symbols-outlined text-white text-sm leading-none">delete</span>
                                        </span>
                                    </label>
                                    <!-- Red overlay when marked for deletion -->
                                    <div id="overlay_@image.Id" class="absolute inset-0 bg-red-600/30 rounded-xl hidden pointer-events-none"></div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-6 text-gray-500">
                            <span class="material-symbols-outlined text-3xl mb-2 block">image_not_supported</span>
                            <p class="text-sm">No images yet</p>
                        </div>
                    }

                    <!-- Upload New Images -->
                    <div class="border-t border-white/5 pt-4">
                        <p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-widest">Add More Images</p>
                        <div class="relative group">
                            <input type="file" id="imageInput" asp-for="Uploads"
                                   accept="image/png, image/jpeg, image/jpg, image/gif, image/webp"
                                   multiple
                                   class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                            <div class="border-2 border-dashed border-white/10 group-hover:border-primary/50 rounded-2xl p-6 flex flex-col items-center justify-center text-center transition-all bg-white/[0.02]">
                                <span class="material-symbols-outlined text-3xl text-gray-500 mb-2 group-hover:text-primary transition-colors">add_photo_alternate</span>
                                <p class="text-sm font-bold text-gray-300">Click or drag images</p>
                                <p class="text-xs text-gray-500 mt-1">PNG, JPG, WEBP · Multiple allowed</p>
                            </div>
                        </div>

                        <span id="imageError" class="text-red-400 text-xs font-medium hidden block mt-2"></span>
                        <span asp-validation-for="Uploads" class="text-red-400 text-xs font-medium"></span>

                        <div id="previewContainer" class="grid grid-cols-2 gap-3 mt-3">
                            <!-- New image previews injected here -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl">
                <button type="submit" class="w-full bg-primary hover:bg-blue-600 text-white py-4 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">update</span>
                    Save Changes
                </button>
                <a asp-action="Index" class="w-full mt-3 inline-flex items-center justify-center py-3 text-gray-400 hover:text-white font-medium transition-colors">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    
    <script>
        // Toggle red overlay when image is marked for deletion
        function toggleDeleteMark(checkbox) {
            const overlay = document.getElementById('overlay_' + checkbox.id.replace('del_', ''));
            if (overlay) overlay.classList.toggle('hidden', !checkbox.checked);
        }

        // Preview new images before upload
        document.getElementById('imageInput').addEventListener('change', function (event) {
            const files = event.target.files;
            const previewContainer = document.getElementById('previewContainer');
            const errorSpan = document.getElementById('imageError');

            previewContainer.innerHTML = '';

            if (files && files.length > 0) {
                let hasInvalidFile = false;
                Array.from(files).forEach(file => {
                    if (!file.type.startsWith('image/')) hasInvalidFile = true;
                });

                if (hasInvalidFile) {
                    errorSpan.textContent = 'Please select valid image files only.';
                    errorSpan.classList.remove('hidden');
                    event.target.value = '';
                    return;
                } else {
                    errorSpan.classList.add('hidden');
                }

                Array.from(files).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const wrapper = document.createElement('div');
                        wrapper.className = 'aspect-square rounded-xl overflow-hidden border border-primary/40 bg-white/5 relative';

                        const badge = document.createElement('span');
                        badge.className = 'absolute top-1 left-1 text-xs bg-primary text-white px-2 py-0.5 rounded-full font-bold z-10';
                        badge.textContent = 'NEW';

                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'w-full h-full object-cover';

                        wrapper.appendChild(badge);
                        wrapper.appendChild(img);
                        previewContainer.appendChild(wrapper);
                    };
                    reader.readAsDataURL(file);
                });
            }
        });
    </script>
}
}