@model ecommerce_system.Models.Proudect

@{
    ViewData["Title"] = "Delete Product";
}

<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Delete Product - Inventory Pro</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#4d8eff",
                        "on-error": "#690005",
                        "outline": "#8c909f",
                        "surface-variant": "#2e353f",
                        "inverse-primary": "#005ac2",
                        "surface": "#0d141d",
                        "surface-container": "#192029",
                        "surface-container-low": "#151c25",
                        "surface-container-high": "#232a34",
                        "surface-container-highest": "#2e353f",
                        "surface-dim": "#0d141d",
                        "on-surface": "#dce3f0",
                        "on-surface-variant": "#c2c6d6",
                        "background": "#0d141d",
                        "primary": "#adc6ff",
                        "on-primary": "#002e6a",
                        "secondary": "#4edea3",
                        "secondary-container": "#00a572",
                        "error": "#ffb4ab"
                    },
                    fontFamily: {
                        sans: ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-background text-on-surface antialiased flex h-screen overflow-hidden">

    <!-- ================= SIDEBAR ================= -->
    <aside class="hidden md:flex flex-col bg-surface-dim text-primary w-64 h-full border-r border-surface-variant p-6 shrink-0">
        <div class="mb-8">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-primary-container text-on-primary flex items-center justify-center font-bold">
                    IP
                </div>
                <div>
                    <h1 class="text-xl font-bold text-primary">Inventory Pro</h1>
                    <p class="text-sm text-on-surface-variant">Global Admin</p>
                </div>
            </div>
        </div>

        <a asp-action="Create"
           class="w-full bg-primary text-on-primary py-3 rounded-lg mb-8 flex items-center justify-center gap-2 hover:opacity-90 transition">
            <span class="material-symbols-outlined">add</span>
            Add New Product
        </a>

        <nav class="flex flex-col gap-2">
            <a asp-action="Index" class="flex items-center gap-3 bg-secondary-container text-black rounded-lg px-4 py-3">
                <span class="material-symbols-outlined">inventory_2</span>
                Products
            </a>

            <a asp-controller="Categories" asp-action="Index" class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-variant rounded-lg">
                <span class="material-symbols-outlined">category</span>
                Categories
            </a>
        </nav>

        <div class="mt-auto pt-6 border-t border-surface-variant">
            <a asp-controller="Home" asp-action="Index"
               class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-variant rounded-lg">
                <span class="material-symbols-outlined">arrow_back</span>
                Back Home
            </a>
        </div>
    </aside>

    <!-- ================= MAIN ================= -->
    <div class="flex flex-col flex-1 overflow-hidden">

        <!-- TOPBAR -->
        <header class="bg-surface-container flex justify-between items-center px-8 h-16 border-b border-surface-variant">
            <h2 class="text-2xl font-semibold text-error">Delete Product</h2>

            <a asp-action="Index"
               class="text-on-surface-variant hover:text-primary transition">
                Cancel
            </a>
        </header>

        <!-- ================= CONTENT ================= -->
        <main class="flex-1 overflow-y-auto p-8">

            <div class="mb-8">
                <div class="bg-error/10 border border-error/20 text-error px-6 py-4 rounded-xl flex items-start gap-4 mb-8">
                    <span class="material-symbols-outlined text-3xl">warning</span>
                    <div>
                        <h1 class="text-2xl font-bold mb-1">Are you sure you want to delete this?</h1>
                        <p class="opacity-90">This action cannot be undone. This will permanently delete the product <strong>@Model.Name</strong>.</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

                <!-- ================= LEFT COLUMN ================= -->
                <div class="lg:col-span-8 space-y-8">

                    <!-- DETAILS -->
                    <div class="bg-surface-container border border-surface-variant rounded-xl p-6">
                        <h3 class="text-xl font-semibold mb-6 border-b border-surface-variant pb-3">
                            Product Details
                        </h3>

                        <dl class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            
                            <div class="md:col-span-1">
                                <dt class="text-sm text-on-surface-variant uppercase mb-1">@Html.DisplayNameFor(model => model.Name)</dt>
                                <dd class="font-medium text-lg">@Html.DisplayFor(model => model.Name)</dd>
                            </div>

                            <div class="md:col-span-1">
                                <dt class="text-sm text-on-surface-variant uppercase mb-1">@Html.DisplayNameFor(model => model.Price)</dt>
                                <dd class="font-medium text-lg text-primary">$@Html.DisplayFor(model => model.Price)</dd>
                            </div>

                            <div class="md:col-span-1">
                                <dt class="text-sm text-on-surface-variant uppercase mb-1">@Html.DisplayNameFor(model => model.Category)</dt>
                                <dd class="font-medium text-lg">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full bg-surface-variant text-on-surface text-sm border border-outline-variant">
                                        @Html.DisplayFor(model => model.Category.Name)
                                    </span>
                                </dd>
                            </div>

                            <div class="md:col-span-3">
                                <dt class="text-sm text-on-surface-variant uppercase mb-1">@Html.DisplayNameFor(model => model.Description)</dt>
                                <dd class="bg-surface-dim p-4 rounded-lg border border-surface-variant text-on-surface">
                                    @Html.DisplayFor(model => model.Description)
                                </dd>
                            </div>

                        </dl>
                    </div>
                </div>

                <!-- ================= RIGHT COLUMN ================= -->
                <div class="lg:col-span-4 space-y-8">

                    <!-- IMAGE PREVIEW -->
                    <div class="bg-surface-container border border-surface-variant rounded-xl p-6">
                        <h3 class="text-xl font-semibold mb-6 border-b border-surface-variant pb-3">
                            Image
                        </h3>

                        <div class="aspect-square rounded-lg border border-surface-variant bg-surface-dim overflow-hidden flex flex-col items-center justify-center">
                            @if (!string.IsNullOrEmpty(Model.Img))
                            {
                                <img src="@Model.Img" alt="@Model.Name" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="text-center text-on-surface-variant p-4">
                                    <span class="material-symbols-outlined text-6xl mb-2">image_not_supported</span>
                                    <p>No image available</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="bg-surface-container border border-surface-variant rounded-xl p-6">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            
                            <div class="flex flex-col gap-4">
                                <button type="submit" class="w-full bg-error text-[#690005] py-3 rounded-lg font-bold hover:opacity-90 transition flex items-center justify-center gap-2">
                                    <span class="material-symbols-outlined">delete_forever</span>
                                    Confirm Delete
                                </button>

                                <a asp-action="Index" class="w-full text-center border border-surface-variant py-3 rounded-lg text-on-surface-variant hover:bg-surface-variant transition">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>

                </div>
            </div>

        </main>
    </div>

</body>
</html>
