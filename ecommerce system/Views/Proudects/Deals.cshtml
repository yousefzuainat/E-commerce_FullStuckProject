@model IEnumerable<ecommerce_system.Models.Proudect>
@{
    ViewData["Title"] = "Deals";
}

@section Styles {
    <link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
}

<div class="prod-page-bar">
    <div class="prod-page-bar-inner">
        <div>
            <p class="sec-eye">Limited Time</p>
            <h1 class="sec-ttl">HOT<br />DEALS</h1>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="prod-empty">
        <div class="prod-empty-ico">🏷️</div>
        <h3 class="prod-empty-ttl">No Deals Right Now</h3>
        <p class="prod-empty-sub">Check back later for discounts.</p>
    </div>
}
else
{
    <div class="prod-admin-grid">
        @foreach (var item in Model)
        {
            var discount = item.Discounts?
                .Select(d => d.DiscountPercent)
                .DefaultIfEmpty(0m)
                .Max() ?? 0m;

            var finalPrice = item.Price * (1 - discount / 100m);

            // Calculate Stars safely
            int totalReviews = item.Reviews?.Count ?? 0;
            double avgRating = totalReviews > 0 ? item.Reviews!.Average(r => r.Rating) : 0;
            int fullStars = (int)Math.Round(avgRating);

            <div class="pag-card">
                <!-- ═══════ Clickable image & body ═══════ -->
                <a asp-action="Details" asp-route-id="@item.Id" class="prod-card-link">
                    <div class="pag-thumb">
                        @if (!string.IsNullOrEmpty(item.Img))
                        {
                            <img src="~@item.Img" alt="@item.Name" class="pag-thumb-img" asp-append-version="true" />
                        }
                        else
                        {
                            <span class="pag-thumb-emoji">🛍️</span>
                        }

                        @* Logic-based badges (No Model Changes Required) *@
                        @{
                            // Calculate discount for this specific item loop
                            var discountPercent = item.Discounts?.Select(d => d.DiscountPercent).DefaultIfEmpty(0m).Max() ?? 0m;
                            int rCount = item.Reviews?.Count ?? 0;
                        }

                        @if (discountPercent > 0)
                        {
                            @* Shows the discount percentage if it exists *@
                            <span class="p-badge badge-sale">@discountPercent.ToString("0")% OFF</span>
                        }
                        else if (rCount > 5)
                        {
                            @* fallback badge: if it has many reviews, call it "HOT" *@
                            <span class="p-badge badge-hot">HOT ★</span>
                        }
                        else if (item.Id > 0)
                        @* Adjust logic here for "New" items if you have a date *@
                        {
                            <span class="p-badge badge-new">NEW</span>
                        }
                    </div>

                    <div class="pag-body">
                        <div class="pag-cat">@(item.Category?.Name ?? "Uncategorized")</div>
                        <div class="pag-name">@item.Name</div>
                        
                        @* Darker description with auto-ellipsis from CSS *@
                        <div class="pag-desc-preview">@item.Description</div>
                        <p class="p-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= fullStars)
                                {
                                    <span style="color: #f5a623;">★</span>
                                }
                                else
                                {
                                    <span style="color: #ccc;">★</span>
                                }
                            }
                            <span class="p-rc">(@totalReviews)</span>
                        </p>
                        <div class="pag-foot">
                            <span class="pag-price">@finalPrice.ToString("C")</span>
                            @if (discount > 0)
                            {
                                <span class="pag-old">@item.Price.ToString("C")</span>
                            }
                        </div>
                    </div>
                </a>

                <!-- ═══════ Standardized Buttons ═══════ -->
                <div class="pag-actions">
                    @* Note: These are now nested anchors. See CSS below to handle this. *@
                    @* <span class="pag-btn pag-btn-ghost">Details</span> *@
                    <!-- Wishlist Form -->
                    <form asp-action="AddToWishlist" asp-controller="WishListItems" method="post" class="action-form" data-ajax="true" style="flex:1;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.Id" />
                        <button type="submit" class="pag-btn pag-btn-ghost">
                            <span>♥</span> WISHLIST
                        </button>
                    </form>                   @* <button type="button" class="pag-btn pag-btn-danger">Add To Cart</button> *@
                    <button class="pag-btn pag-btn-danger" data-product-id="@item.Id" onclick="addToCart(this)">Add To Cart</button>
                </div>

            </div>
        }
    </div>
}

@section Scripts {

    <script src="~/js/products.js" asp-append-version="true"></script>
    <script src="~/js/Cart.js" asp-append-version="true"></script>

