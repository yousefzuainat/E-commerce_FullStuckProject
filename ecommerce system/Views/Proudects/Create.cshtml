@model ecommerce_system.ViewModel.ProudectCreateViewModel

@{
    ViewData["Title"] = "Add New Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="max-w-5xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-white mb-2 tracking-tight">Create New Product</h1>
            <p class="text-gray-400 font-medium">Add a new item to your store inventory.</p>
        </div>
        <a asp-action="Index" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors font-medium">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to List
        </a>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Form Area -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information -->
            <div class="glass-panel rounded-2xl p-8 border border-white/5 shadow-xl">
                <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">info</span>
                    Basic Information
                </h3>
                
                <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm"></div>

                <div class="space-y-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-bold text-gray-300 mb-2">Product Name</label>
                        <input asp-for="Name" placeholder="e.g. Premium Wireless Headphones"
                               class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                        <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-bold text-gray-300 mb-2">Description</label>
                        <textarea asp-for="Description" placeholder="Tell customers more about this product..."
                                  rows="6"
                                  class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all"></textarea>
                        <span asp-validation-for="Description" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>
                </div>
            </div>

            <!-- Pricing & Inventory -->
            <div class="glass-panel rounded-2xl p-8 border border-white/5 shadow-xl">
                <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">payments</span>
                    Pricing & Category
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Price" class="block text-sm font-bold text-gray-300 mb-2">Base Price</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
                            <input asp-for="Price" placeholder="0.00" type="number" step="0.01"
                                   class="w-full bg-white/5 border border-white/10 rounded-xl py-3 pl-8 pr-4 text-white placeholder-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                        </div>
                        <span asp-validation-for="Price" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>

                    <div>
                        <label asp-for="DiscountPercent" class="block text-sm font-bold text-gray-300 mb-2">Discount Percentage</label>
                        <div class="relative">
                            <input asp-for="DiscountPercent" placeholder="0" type="number" min="0" max="100"
                                   class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">%</span>
                        </div>
                        <span asp-validation-for="DiscountPercent" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="CategoryId" class="block text-sm font-bold text-gray-300 mb-2">Category</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId"
                                class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all appearance-none">
                            <option value="" class="bg-[#192029]">Select a category...</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Area -->
        <div class="space-y-6">
            <!-- Media Upload -->
            <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl">
                <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">image</span>
                    Product Media
                </h3>

                <div class="space-y-4">
                    <div class="relative group">
                        <input type="file" id="imageInput" asp-for="Uploads"
                               accept="image/png, image/jpeg, image/jpg, image/gif, image/webp"
                               multiple
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                        <div class="border-2 border-dashed border-white/10 group-hover:border-primary/50 rounded-2xl p-8 flex flex-col items-center justify-center text-center transition-all bg-white/[0.02]">
                            <span class="material-symbols-outlined text-4xl text-gray-500 mb-2 group-hover:text-primary transition-colors">cloud_upload</span>
                            <p class="text-sm font-bold text-gray-300">Click or drag images</p>
                            <p class="text-xs text-gray-500 mt-1">PNG, JPG, WEBP up to 5MB</p>
                        </div>
                    </div>
                    
                    <span id="imageError" class="text-red-400 text-xs font-medium hidden"></span>
                    <span asp-validation-for="Uploads" class="text-red-400 text-xs font-medium"></span>

                    <div id="previewContainer" class="grid grid-cols-2 gap-3 min-h-[100px]">
                        <!-- Previews will be injected here -->
                    </div>
                </div>
            </div>

            <!-- Publish Card -->
            <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl">
                <button type="submit" class="w-full bg-primary hover:bg-blue-600 text-white py-4 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">save</span>
                    Publish Product
                </button>
                <a asp-action="Index" class="w-full mt-3 inline-flex items-center justify-center py-3 text-gray-400 hover:text-white font-medium transition-colors">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    
    <script>
        document.getElementById('imageInput').addEventListener('change', function (event) {
            const files = event.target.files;
            const previewContainer = document.getElementById('previewContainer');
            const errorSpan = document.getElementById('imageError'); 

            previewContainer.innerHTML = '';

            if (files && files.length > 0) {
                let hasInvalidFile = false;
                Array.from(files).forEach(file => {
                    if (!file.type.startsWith('image/')) {
                        hasInvalidFile = true;
                    }
                });

                if (hasInvalidFile) {
                    errorSpan.textContent = 'Please select valid image files only.'; 
                    errorSpan.classList.remove('hidden'); 
                    event.target.value = ''; 
                    return; 
                } else {
                    errorSpan.classList.add('hidden');
                }

                Array.from(files).forEach(file => {
                    const reader = new FileReader(); 
                    reader.onload = function (e) { 
                        const wrapper = document.createElement('div');
                        wrapper.className = 'aspect-square rounded-xl overflow-hidden border border-white/10 bg-white/5 relative group';
                        
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'w-full h-full object-cover transition-transform group-hover:scale-110';
                        
                        wrapper.appendChild(img);
                        previewContainer.appendChild(wrapper);
                    } 
                    reader.readAsDataURL(file); 
                });
            }
        });
    </script>
}
