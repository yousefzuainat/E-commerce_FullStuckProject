@model IEnumerable<ecommerce_system.Models.AppliactionUser>

@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
        <h1 class="text-3xl font-black text-white mb-2 tracking-tight">User Management</h1>
        <p class="text-gray-400 font-medium">Manage your system users and their permissions.</p>
    </div>
</div>

<div class="glass-panel rounded-3xl border border-white/5 overflow-hidden shadow-2xl">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-white/5 border-b border-white/5">
                    <th class="px-6 py-5 text-xs font-black text-gray-500 uppercase tracking-widest">User</th>
                    <th class="px-6 py-5 text-xs font-black text-gray-500 uppercase tracking-widest">Email</th>
                    <th class="px-6 py-5 text-xs font-black text-gray-500 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-white/[0.02] transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
                                    @(user.FullName?.FirstOrDefault() ?? user.Email?.FirstOrDefault() ?? '?')
                                </div>
                                <div>
                                    <div class="text-sm font-bold text-white group-hover:text-primary transition-colors">@user.FullName</div>
                                    <div class="text-[10px] text-gray-500 font-medium truncate max-w-[150px]">ID: @user.Id</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-sm text-gray-400 font-medium">@user.Email</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="w-9 h-9 inline-flex items-center justify-center bg-white/5 hover:bg-amber-500/20 hover:text-amber-400 text-gray-300 rounded-lg transition-all border border-white/5" title="Edit">
                                    <span class="material-symbols-outlined text-lg">edit</span>
                                </a>
                                <a asp-action="DeleteUser" asp-route-id="@user.Id" class="w-9 h-9 inline-flex items-center justify-center bg-white/5 hover:bg-red-500/20 hover:text-red-500 text-gray-300 rounded-lg transition-all border border-white/5" title="Delete">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
