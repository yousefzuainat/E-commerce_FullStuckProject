@model ecommerce_system.Models.AppliactionUser

@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-white mb-2 tracking-tight">Edit User</h1>
            <p class="text-gray-400 font-medium">Update account details for <span class="text-primary">@Model.Email</span></p>
        </div>
        <a asp-action="Users" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors font-medium">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to Users
        </a>
    </div>

    <form asp-action="EditUser" method="post" class="space-y-6">
        <input type="hidden" asp-for="Id" />
        
        <div class="glass-panel rounded-2xl p-8 border border-white/5 shadow-xl">
            <div class="space-y-6">
                <div>
                    <label asp-for="FullName" class="block text-sm font-bold text-gray-300 mb-2">Full Name</label>
                    <input asp-for="FullName" placeholder="Full Name"
                           class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                    <span asp-validation-for="FullName" class="text-red-400 text-xs mt-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-gray-300 mb-2">Email Address</label>
                    <input asp-for="Email" placeholder="email@example.com"
                           class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                    <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block font-medium"></span>
                </div>
            </div>
        </div>

        <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl flex gap-4">
            <button type="submit" class="flex-1 bg-primary hover:bg-blue-600 text-white py-4 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">save</span>
                Update Account
            </button>
            <a asp-action="Users" class="px-8 bg-white/5 hover:bg-white/10 text-gray-300 py-4 rounded-xl font-bold transition-all flex items-center justify-center">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
