@model ecommerce_system.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Your Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Testimonials.css" asp-append-version="true" />
}

<div class="cart-page">

    @* ── Page Header ── *@
    <div class="cart-hd">
        <div class="cart-hd-inner">
            <p class="cart-eye">Your Selection</p>
            <h1 class="cart-title">SHOPPING<br /><span class="cart-title-accent">CART</span></h1>
            @if (Model.Items.Any())
            {
                <p class="cart-count-lbl">@Model.TotalQuantity item@(Model.TotalQuantity != 1 ? "s" : "") in your cart</p>
            }
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="cart-empty">
            <div class="cart-empty-icon">🛒</div>
            <h2 class="cart-empty-ttl">Your cart is empty</h2>
            <p class="cart-empty-sub">Looks like you haven't added anything yet. Browse our products and find something you love.</p>
            <a href="/Proudects" class="btn-p">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            @* ── Items Column ── *@
            <div class="cart-items-col" id="cartItemsCol">
                @foreach (var item in Model.Items)
                {
                    <div class="cart-item" data-product-id="@item.ProductId" style="display: grid; grid-template-columns: 88px 1fr auto auto 36px; align-items: center; gap: 24px;">
                        
                        @* 1. Thumbnail Column *@
                        <div class="cart-item-img">
                            @{
                                var img = item.Img ?? "";
                                if (img.StartsWith("/") || img.StartsWith("http"))
                                {
                                    <img src="@img" alt="@item.Name" style="width:100%; height:100%; object-fit:contain; padding:6px;" />
                                }
                                else
                                {
                                    <span class="cart-item-emoji">@(string.IsNullOrEmpty(img) ? "📦" : img)</span>
                                }
                            }
                        </div>

                        @* 2. Description Details Column *@
                        <div class="cart-item-info" style="display: flex; flex-direction: column; justify-content: center;">
                            <p class="cart-item-brand">@item.Brand</p>
                            <p class="cart-item-name" style="margin-bottom: 6px;">@item.Name</p>

                            <div class="cart-item-price-wrap">
                                @if (item.HasDiscount)
                                {
                                    <span class="cart-item-original" style="display:block; font-size:11px; text-decoration:line-through; opacity:0.6;">$@item.Price.ToString("F2")</span>
                                    <span class="cart-item-final" id="unit-price-@item.ProductId" style="font-weight:700; color:var(--text);">
                                        $@item.DiscountedPrice.ToString("F2") <small style="font-size:10px; opacity:.7">/ea</small>
                                    </span>
                                    <span class="disc-badge" style="margin-top:4px;">🏷 @((int)item.DiscountPercent)% OFF</span>
                                }
                                else
                                {
                                    <span class="cart-item-price" id="unit-price-@item.ProductId" style="font-weight:700;">$@item.Price.ToString("F2")</span>
                                }
                            </div>
                        </div>

                        @* 3. Interactive Controls Column *@
                        <div class="cart-item-controls" style="display: flex; align-items: center; justify-content: center;">
                            <div class="qty-ctrl" style="display: flex; align-items: center;">
                                <button class="qty-btn qty-minus" data-id="@item.ProductId" aria-label="Decrease">−</button>
                                <span class="qty-val" id="qty-@item.ProductId">@item.Quantity</span>
                                <button class="qty-btn qty-plus" data-id="@item.ProductId" aria-label="Increase">+</button>
                            </div>
                        </div>

                        @* 4. Sum Line Total Column *@
                        <div style="display: flex; align-items: center; justify-content: flex-end; min-width: 90px;">
                            <p class="cart-item-line" id="line-@item.ProductId" style="margin:0; font-weight:800; font-size:16px;">$@item.LineTotal.ToString("F2")</p>
                        </div>

                        @* 5. Remove Target Column *@
                        <button class="cart-item-remove" data-id="@item.ProductId" aria-label="Remove item">✕</button>
                    </div>
                }
            </div>

            @* ── Summary Column ── *@
            <div class="cart-summary">
                <div class="cart-summary-inner">
                    <h2 class="summary-ttl">Order Summary</h2>

                    @* Savings row (only visible when discounts exist) *@
                    @if (Model.TotalSavings > 0)
                    {
                        <div id="savingsRow" class="savings-row">
                            <span>🏷 You Save</span>
                            <span id="summarySavings">-$@Model.TotalSavings.ToString("F2")</span>
                        </div>
                    }
                    else
                    {
                        <div id="savingsRow" class="savings-row" style="display:none">
                            <span>🏷 You Save</span>
                            <span id="summarySavings">-$0.00</span>
                        </div>
                    }

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span id="summarySubtotal">$@Model.Subtotal.ToString("F2")</span>
                    </div>

                    <div class="summary-divider"></div>
                    <div class="summary-row summary-total">
                        <span>Total</span>
                        <span id="summaryTotal">$@Model.Total.ToString("F2")</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Cart" asp-action="Checkout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="checkout-btn">Proceed to Checkout →</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login"
                           asp-route-returnUrl="/Cart"
                           class="checkout-btn checkout-login-btn">Login to Checkout →</a>
                        <p class="checkout-note">You'll be returned to your cart after login.</p>
                    }

                    <a href="/Proudects" class="continue-shopping">← Continue Shopping</a>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    <script>
        function showToast(msg, type = 'success') {
            const t = document.createElement('div');
            t.className = 'cart-toast cart-toast-' + type;
            t.textContent = msg;
            document.body.appendChild(t);
            requestAnimationFrame(() => t.classList.add('show'));
            setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 350); }, 2200);
        }

        function updateBadge(count) {
            document.querySelectorAll('.cart-n').forEach(el => {
                el.textContent = count;
                el.classList.toggle('cart-n-active', count > 0);
            });
        }

        function updateSummary(data) {
            const sub  = document.getElementById('summarySubtotal');
            const tot  = document.getElementById('summaryTotal');
            const sav  = document.getElementById('summarySavings');
            const savRow = document.getElementById('savingsRow');

            if (sub)  sub.textContent  = '$' + data.subtotal;
            if (tot)  tot.textContent  = '$' + data.total;

            if (sav && savRow && data.savings !== undefined) {
                const s = parseFloat(data.savings);
                savRow.style.display = s > 0 ? '' : 'none';
                sav.textContent = '-$' + s.toFixed(2);
            }
        }

        // ── REMOVE ──
        document.querySelectorAll('.cart-item-remove').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id  = this.dataset.id;
                const row = this.closest('.cart-item');
                row.classList.add('removing');
                const res = await fetch('/Cart/Remove', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                    body: 'productId=' + id
                });
                const data = await res.json();
                if (data.success) {
                    setTimeout(() => {
                        row.remove();
                        updateBadge(data.cartCount);
                        updateSummary(data);
                        if (data.isEmpty) location.reload();
                    }, 300);
                    showToast('Item removed from cart');
                }
            });
        });

        // ── QUANTITY ──
        async function changeQty(productId, delta) {
            const qtyEl   = document.getElementById('qty-' + productId);
            const current = parseInt(qtyEl.textContent);
            const newQty  = current + delta;
            if (newQty < 1) return;

            const res = await fetch('/Cart/Update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getToken() },
                body: 'productId=' + productId + '&quantity=' + newQty
            });
            const data = await res.json();
            if (data.success) {
                qtyEl.textContent = newQty;
                const lineEl = document.getElementById('line-' + productId);
                if (lineEl) lineEl.textContent = '$' + data.lineTotal;
                updateBadge(data.cartCount);
                updateSummary(data);
            }
        }

        document.querySelectorAll('.qty-minus').forEach(btn => {
            btn.addEventListener('click', () => changeQty(btn.dataset.id, -1));
        });
        document.querySelectorAll('.qty-plus').forEach(btn => {
            btn.addEventListener('click', () => changeQty(btn.dataset.id, +1));
        });

        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('meta[name="csrf-token"]')?.content || '';
        }
    </script>
}