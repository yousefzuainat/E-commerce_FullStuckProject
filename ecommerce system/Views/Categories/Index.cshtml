@model IEnumerable<ecommerce_system.Models.Category>

@{
    ViewData["Title"] = "Categories List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
        <h1 class="text-3xl font-black text-white mb-2 tracking-tight">Product Categories</h1>
        <p class="text-gray-400 font-medium">Organize your inventory with custom categories.</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">search</span>
            <input type="text" id="catSearch" placeholder="Search categories..." 
                   class="bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/50 text-white placeholder-gray-500 w-full md:w-64 transition-all" />
        </div>
        <a asp-action="Create" class="inline-flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-5 py-2 rounded-xl font-bold transition-all shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined text-lg">add</span>
            Add Category
        </a>
    </div>
</div>

<!-- STATS CARDS -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
            <span class="material-symbols-outlined">category</span>
        </div>
        <div>
            <div class="text-2xl font-black text-white">@Model.Count()</div>
            <div class="text-xs text-gray-500 font-bold uppercase tracking-wider">Categories</div>
        </div>
    </div>
    <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500">
            <span class="material-symbols-outlined">inventory_2</span>
        </div>
        <div>
            <div class="text-2xl font-black text-white">@Model.Sum(c => c.Proudects?.Count ?? 0)</div>
            <div class="text-xs text-gray-500 font-bold uppercase tracking-wider">Total Products</div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="flex flex-col items-center justify-center py-20 glass-panel rounded-3xl border border-white/5">
        <span class="material-symbols-outlined text-6xl text-gray-700 mb-4">folder_open</span>
        <h3 class="text-xl font-bold text-white mb-2">No categories found</h3>
        <p class="text-gray-400 mb-8 max-w-sm text-center">Get started by creating your first product category to organize your inventory.</p>
        <a asp-action="Create" class="bg-primary hover:bg-blue-600 text-white px-8 py-3 rounded-xl font-bold transition-all">
            + Create Category
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="catGrid">
        @foreach (var cat in Model)
        {
            <div class="cat-card group glass-panel rounded-2xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all duration-300 hover:-translate-y-1 shadow-lg hover:shadow-primary/10" 
                 data-name="@cat.Name.ToLower()">
                
                <div class="relative aspect-video bg-white/5 flex items-center justify-center overflow-hidden">
                    @if (!string.IsNullOrEmpty(cat.Img))
                    {
                        <img src="~/images/Categories/@cat.Img" alt="@cat.Name" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" asp-append-version="true" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-4xl text-gray-600">folder</span>
                    }
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                        <span class="text-white text-xs font-bold uppercase tracking-widest">ID: #@cat.Id</span>
                    </div>
                </div>
                
                <div class="p-5">
                    <h3 class="text-lg font-bold text-white mb-1 group-hover:text-primary transition-colors truncate">@cat.Name</h3>
                    <p class="text-gray-500 text-sm font-medium mb-4">@(cat.Proudects?.Count ?? 0) Products</p>
                    
                    <div class="flex items-center gap-2 pt-4 border-t border-white/5">
                        <a asp-action="Details" asp-route-id="@cat.Id" class="flex-grow inline-flex items-center justify-center gap-1.5 bg-white/5 hover:bg-white/10 text-gray-300 py-2 rounded-lg text-xs font-bold transition-all border border-white/5">
                            Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@cat.Id" class="w-9 h-9 inline-flex items-center justify-center bg-white/5 hover:bg-amber-500/20 hover:text-amber-400 text-gray-300 rounded-lg transition-all border border-white/5" title="Edit">
                            <span class="material-symbols-outlined text-lg">edit</span>
                        </a>
                        <a asp-action="Delete" asp-route-id="@cat.Id" class="w-9 h-9 inline-flex items-center justify-center bg-white/5 hover:bg-red-500/20 hover:text-red-500 text-gray-300 rounded-lg transition-all border border-white/5" title="Delete">
                            <span class="material-symbols-outlined text-lg">delete</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <div id="catNoResults" class="hidden text-center py-20 glass-panel rounded-2xl mt-4 border border-white/5">
        <span class="material-symbols-outlined text-6xl mb-4 text-gray-700">search_off</span>
        <h3 class="text-xl font-bold text-white mb-1">No matching categories</h3>
        <p class="text-gray-400">We couldn't find any categories matching your search.</p>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('catSearch')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.cat-card');
            let hasVisible = false;
            
            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                if (name.includes(searchTerm)) {
                    card.style.display = '';
                    hasVisible = true;
                } else {
                    card.style.display = 'none';
                }
            });
            
            const noResults = document.getElementById('catNoResults');
            if (noResults) {
                if (!hasVisible && cards.length > 0) {
                    noResults.classList.remove('hidden');
                } else {
                    noResults.classList.add('hidden');
                }
            }
        });
    </script>
}