@model ecommerce_system.Models.Category

@{
    ViewData["Title"] = "Category Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Grotesk:wght@300;400;500&family=Bebas+Neue&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/voltex_pro.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/categories.css" asp-append-version="true" />
}

<div class="page-wrap">
    @* ── Breadcrumb ── *@
    <div class="breadcrumb reveal">
        <a asp-action="Index" class="bc-item">Categories</a>
        <span class="bc-sep">›</span>
        <span class="bc-current">@Model.Name</span>
    </div>

    @* ── Header ── *@
    <div class="page-hdr reveal">
        <div>
            <p class="page-eye">Inventory Overview</p>
            <h1 class="page-ttl">CATEGORY<br>DETAILS</h1>
        </div>
        <div class="hdr-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-v">✏ Edit Category</a>
        </div>
    </div>

    @* ── Details Card ── *@
    <div class="v-card reveal">
        <div class="form-grid">
            
            @* Left: Visual Preview *@
            <div class="preview-panel">
                <span class="preview-lbl">Category Visual</span>
                <div class="preview-box">
                    @if (!string.IsNullOrEmpty(Model.Img))
                    {
                        <img src="~/images/Categories/@Model.Img" alt="@Model.Name" class="cag-img" style="display:block; width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <div class="preview-placeholder" style="display:flex; flex-direction:column; align-items:center;">
                            <span class="p-ico">🗂️</span>
                            <p>No image assigned</p>
                        </div>
                    }
                </div>
            </div>

            @* Right: Information *@
            <div class="form-panel">
                <div class="form-panel-ttl">Quick Info</div>
                <p class="form-panel-sub">Identification and stats for this category</p>

                <div class="details-list">
                    <div class="field-wrap">
                        <label class="field-lbl">Category Name</label>
                        <p class="det-val">@Model.Name</p>
                    </div>

                    <div class="field-wrap">
                        <label class="field-lbl">System ID</label>
                        <p class="det-val">#@Model.Id</p>
                    </div>

                    <div class="field-wrap">
                        <label class="field-lbl">Current Product Count</label>
                        <div class="csc-num accent2">@(Model.Proudects?.Count ?? 0)</div>
                        <p class="form-panel-sub">Active items assigned to this category</p>
                    </div>
                </div>

                <div class="form-actions" style="margin-top: 40px; border-top: 1px solid var(--border-dim); padding-top: 20px; display: flex; gap: 15px;">
                    <a asp-action="Index" class="btn-ghost-v">← Back to Dashboard</a>
                    @* View Products Button *@
                    <a asp-controller="Proudects" asp-action="Index" asp-route-categoryId="@Model.Id" class="btn-p">View @Model.Name Products</a>
                </div>
            </div>

        </div>
    </div>
</div>

@* @section Scripts {
    <script src="~/js/voltex.js"></script>
} *@