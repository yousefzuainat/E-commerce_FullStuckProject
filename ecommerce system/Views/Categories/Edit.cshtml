@model ecommerce_system.Models.Category
@{
    ViewData["Title"] = "Edit Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/categories.css" asp-append-version="true" />
}

<div class="cat-form-page">

    <div class="cat-form-bar reveal">
        <div>
            <p class="sec-eye">Admin Panel</p>
            <h1 class="sec-ttl">EDIT<br />CATEGORY</h1>
        </div>
        <a asp-action="Index" class="btn-g btn-back">← Back to List</a>
    </div>

    <div class="cat-form-wrap reveal">

        <div class="cat-form-card">

            <div class="cat-form-header">
                <div class="cfh-dot cfh-orange"></div>
                <div class="cfh-dot cfh-yellow"></div>
                <div class="cfh-dot cfh-green"></div>
                <span class="cfh-title">Edit — @Model.Name</span>
            </div>

            <form asp-action="Edit" enctype="multipart/form-data" class="cat-form-body">

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="All" class="cat-validation-summary"></div>

                <div class="cf-field">
                    <label asp-for="Name" class="cf-label">
                        <span class="cf-label-eye">01</span> Category Name
                    </label>
                    <input asp-for="Name" class="cf-input" placeholder="e.g. Audio, Gaming…" />
                    <span asp-validation-for="Name" class="cf-error"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Img))
                {
                    <div class="cf-field">
                        <p class="cf-label"><span class="cf-label-eye">02</span> Current Image</p>
                        <div class="cf-current-img-wrap">
                            <img src="~/images/Categories/@Model.Img" alt="current" class="cf-current-img" />
                        </div>
                    </div>
                }

                <div class="cf-field">
                    <label class="cf-label">
                        <span class="cf-label-eye">@(string.IsNullOrEmpty(Model.Img) ? "02" : "03")</span>
                        Replace Image
                        <span class="cf-label-opt">(optional)</span>
                    </label>
                    <label class="cf-file-drop" id="catFileDrop" for="catImageInput">
                        <span class="cf-file-ico">📁</span>
                        <span class="cf-file-txt" id="catFileName">Click or drag a new image</span>
                        <span class="cf-file-hint">PNG, JPG, WEBP — images only</span>
                    </label>
                    @* <input type="file" name="upload" id="catImageInput" accept="image/*" class="cf-file-hidden" /> *@
                    <input type="file" name="imageFile" id="catImageInput" class="form-control cf-file-hidden" />
                    <span id="catImageError" class="cf-error" style="display:none;"></span>
                </div>

                <div class="cf-actions">
                    <button type="submit" class="btn-p cf-submit">💾 Save Changes</button>
                    <a asp-action="Index" class="btn-g cf-cancel">Cancel</a>
                </div>

            </form>
        </div>

        <div class="cat-form-preview">
            <div class="cfp-label">Live Preview</div>
            <div class="cfp-card-wrap">
                <div class="cfp-card">
                    <div class="cfp-fig" id="cfpFig">
                        @if (!string.IsNullOrEmpty(Model.Img))
                        {
                            <img id="cfpImg" src="~/images/Categories/@Model.Img" alt="preview" style="display:block;" />
                            <span class="cfp-placeholder-ico" id="cfpPlaceholder" style="display:none;">🗂️</span>
                        }
                        else
                        {
                            <img id="cfpImg" src="~/images/Categories/@Model.Img" alt="preview" style="display:block;" />
                            <span class="cfp-placeholder-ico" id="cfpPlaceholder">🗂️</span>
                        }
                    </div>
                    <div class="cfp-info">
                        <div class="cfp-count">@(Model.Proudects?.Count ?? 0) products</div>
                        <div class="cfp-name" id="cfpName">@Model.Name</div>
                        <div class="cfp-arr">→</div>
                    </div>
                </div>
            </div>
            <p class="cfp-hint">Changes will be reflected on the storefront after saving.</p>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/categories-create.js" asp-append-version="true"></script>
}
