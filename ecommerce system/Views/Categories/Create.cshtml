@model ecommerce_system.Models.Category
@{
    ViewData["Title"] = "Add New Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-5xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-white mb-2 tracking-tight">Create Category</h1>
            <p class="text-gray-400 font-medium">Organize your products with a new category.</p>
        </div>
        <a asp-action="Index" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors font-medium">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to List
        </a>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Form Area -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information -->
            <div class="glass-panel rounded-2xl p-8 border border-white/5 shadow-xl">
                <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">category</span>
                    Category Details
                </h3>
                
                <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl text-sm"></div>

                <div class="space-y-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-bold text-gray-300 mb-2">Category Name</label>
                        <input asp-for="Name" id="categoryNameInput" placeholder="e.g. Electronics, Fashion, Home..."
                               class="w-full bg-white/5 border border-white/10 rounded-xl py-3 px-4 text-white placeholder-gray-500 focus:ring-2 focus:ring-primary/50 focus:border-primary/50 outline-none transition-all" />
                        <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 block font-medium"></span>
                    </div>
                </div>
            </div>

            <!-- Submit Actions -->
            <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl">
                <button type="submit" class="w-full bg-primary hover:bg-blue-600 text-white py-4 rounded-xl font-bold shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">save</span>
                    Save Category
                </button>
            </div>
        </div>

        <!-- Sidebar Area -->
        <div class="space-y-6">
            <!-- Media Management -->
            <div class="glass-panel rounded-2xl p-6 border border-white/5 shadow-xl">
                <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">image</span>
                    Media Management
                </h3>

                <div class="space-y-4">
                    <div class="relative group">
                        <input type="file" name="imageFile" id="catImageInput" 
                               accept="image/png, image/jpeg, image/jpg, image/gif, image/webp"
                               class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                        <div class="border-2 border-dashed border-white/10 group-hover:border-primary/50 rounded-2xl p-6 flex flex-col items-center justify-center text-center transition-all bg-white/[0.02]">
                            <span class="material-symbols-outlined text-3xl text-gray-500 mb-2 group-hover:text-primary transition-colors">cloud_upload</span>
                            <p class="text-sm font-bold text-gray-300" id="fileNameLabel">Upload Category Image</p>
                            <p class="text-xs text-gray-500 mt-1">PNG, JPG, WEBP — Images only</p>
                        </div>
                    </div>
                    <span id="catImageError" class="text-red-400 text-xs mt-1 block font-medium hidden"></span>
                    
                    <div class="mt-6">
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest mb-3">Live Preview</label>
                        <div class="aspect-square rounded-2xl overflow-hidden bg-white/5 border border-white/10 relative group shadow-inner">
                            <img id="previewImg" src="#" alt="preview" class="w-full h-full object-cover hidden transition-transform duration-500 group-hover:scale-110" />
                            <div id="previewPlaceholder" class="absolute inset-0 flex flex-col items-center justify-center text-gray-600">
                                <span class="material-symbols-outlined text-5xl mb-2">image</span>
                                <p class="text-xs font-bold uppercase tracking-wider">No Image</p>
                            </div>
                            <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/90 via-black/40 to-transparent">
                                <p class="text-white font-bold text-lg leading-tight" id="previewName">Category Name</p>
                                <p class="text-primary text-xs font-bold mt-1">0 Products</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const nameInput = document.getElementById('categoryNameInput');
        const previewName = document.getElementById('previewName');
        const fileInput = document.getElementById('catImageInput');
        const fileNameLabel = document.getElementById('fileNameLabel');
        const errorLabel = document.getElementById('catImageError');
        const previewImg = document.getElementById('previewImg');
        const previewPlaceholder = document.getElementById('previewPlaceholder');

        nameInput.addEventListener('input', (e) => {
            previewName.textContent = e.target.value.trim() || 'Category Name';
        });

        fileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                // Robust image validation
                const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
                if (!allowedTypes.includes(file.type)) {
                    errorLabel.textContent = 'Please select a valid image file (JPG, PNG, GIF, WebP).';
                    errorLabel.classList.remove('hidden');
                    fileNameLabel.textContent = 'Upload Category Image';
                    e.target.value = '';
                    return;
                }
                
                errorLabel.classList.add('hidden');
                fileNameLabel.textContent = file.name;

                const reader = new FileReader();
                reader.onload = (event) => {
                    previewImg.src = event.target.result;
                    previewImg.classList.remove('hidden');
                    previewPlaceholder.classList.add('hidden');
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}

