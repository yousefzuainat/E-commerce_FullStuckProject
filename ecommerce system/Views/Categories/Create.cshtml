@model ecommerce_system.Models.Category
@{
    ViewData["Title"] = "Add New Category";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/categories.css" asp-append-version="true" />
}

<div class="cat-form-page">

    <div class="cat-form-bar reveal">
        <div>
            <p class="sec-eye">Admin Panel</p>
            <h1 class="sec-ttl">ADD<br />CATEGORY</h1>
        </div>
        <a asp-action="Index" class="btn-g btn-back">← Back to List</a>
    </div>

    <div class="cat-form-wrap reveal">

        @* {{!-- ── Left: form ── --}} *@
        <div class="cat-form-card">

            <div class="cat-form-header">
                <div class="cfh-dot cfh-orange"></div>
                <div class="cfh-dot cfh-yellow"></div>
                <div class="cfh-dot cfh-green"></div>
                <span class="cfh-title">Category Details</span>
            </div>

            <form asp-action="Create" enctype="multipart/form-data" class="cat-form-body">

                <div asp-validation-summary="All" class="cat-validation-summary"></div>

                @* {{!-- Name --}} *@
                <div class="cf-field">
                    <label asp-for="Name" class="cf-label">
                        <span class="cf-label-eye">01</span> Category Name
                    </label>
                    <input asp-for="Name"
                           class="cf-input"
                           placeholder="e.g. Audio, Gaming, Workspace…" />
                    <span asp-validation-for="Name" class="cf-error"></span>
                </div>

                @* {{!-- Image upload --}} *@
                <div class="cf-field">
                    <label class="cf-label">
                        <span class="cf-label-eye">02</span> Category Image
                        <span class="cf-label-opt">(optional)</span>
                    </label>
                    <label class="cf-file-drop" id="catFileDrop" for="catImageInput">
                        <span class="cf-file-ico">📁</span>
                        <span class="cf-file-txt" id="catFileName">Click or drag an image here</span>
                        <span class="cf-file-hint">PNG, JPG, WEBP — images only</span>
                    </label>
                    @* <input type="file"
                           name="upload"
                           id="catImageInput"
                           accept="image/*"
                           class="cf-file-hidden" /> *@
                    <input type="file" name="imageFile" id="catImageInput" class="form-control cf-file-hidden" />
                    <span id="catImageError" class="cf-error" style="display:none;"></span>
                    <span asp-validation-for="Img" class="cf-error"></span>
                </div>

                @* {{!-- Submit --}} *@
                <div class="cf-actions">
                    <button type="submit" class="btn-p cf-submit">
                        💾 Save Category
                    </button>
                    <a asp-action="Index" class="btn-g cf-cancel">Cancel</a>
                </div>

            </form>
        </div>

        @* {{!-- ── Right: live preview ── --}} *@
        <div class="cat-form-preview">
            <div class="cfp-label">Live Preview</div>
            <div class="cfp-card-wrap">
                <div class="cfp-card">
                    <div class="cfp-fig" id="cfpFig">
                        <img id="cfpImg" src="#" alt="preview" style="display:none;" />
                        <span class="cfp-placeholder-ico" id="cfpPlaceholder">🗂️</span>
                    </div>
                    <div class="cfp-info">
                        <div class="cfp-count">0 products</div>
                        <div class="cfp-name" id="cfpName">Category Name</div>
                        <div class="cfp-arr">→</div>
                    </div>
                </div>
            </div>
            <p class="cfp-hint">Fill in the form to see a live preview of how this category will appear on the storefront.</p>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/categories-create.js" asp-append-version="true"></script>
}
