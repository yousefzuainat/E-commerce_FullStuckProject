@model ecommerce_system.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}
@* ══════════════════════════════════════════════
     HERO
══════════════════════════════════════════════ *@
<section class="hero">
    <div class="hero-l">
        <span class="h-tag">
            <span class="h-tag-line"></span>
            <span id="hTag">// Season 2026 Drop</span>
        </span>
        <h1 class="h-title" id="hTitle">
            <span class="ht-dim">NEXT</span><br />
            <span class="ht-orange">LEVEL</span><br />
            <span class="ht-yellow">GEAR</span>
        </h1>
        <p class="h-sub" id="hSub">
            Built for champions. From pro peripherals to precision tools — equipment engineered to keep you at the top of your game.
        </p>
        <div class="h-cta">
            <a href="/Categories" class="btn-p">Shop Now</a>
            <a asp-controller="Proudects" asp-action="Index" class="btn-g" id="btn2Txt">Explore Builds</a>
        </div>
        <div class="h-stats">
            <div>
                <div class="stat-n"><em>@Model.Stats.ProductCountFormatted</em>+</div>
                <div class="stat-l">Products</div>
            </div>
            <div>
                <div class="stat-n"><em>@Model.Stats.SatisfactionRate</em>%</div>
                <div class="stat-l">Satisfaction</div>
            </div>
            <div>
                <div class="stat-n"><em>@Model.Stats.BrandCount</em>+</div>
                <div class="stat-l">Brands</div>
            </div>
        </div>
    </div>
    <div class="hero-r">
        <span class="hero-emoji">🎧</span>
        <div class="h-chip ca">
            <div class="chip-lbl">Featured Drop</div>
            <div class="chip-val">@Model.HeroDrop.PriceFormatted</div>
            <div class="chip-sub">@Model.HeroDrop.Name</div>
        </div>
        <div class="h-chip cb">
            <div class="chip-lbl">Rating</div>
            <div class="chip-val">★ 4.9</div>
            <div class="chip-sub">2,100+ Reviews</div>
        </div>
    </div>
</section>

@* ══════════════════════════════════════════════
     TICKER
══════════════════════════════════════════════ *@
<div class="ticker">
    <div class="tick-track">
        @{
            var tickers = new[] {
                "Free Shipping Over $75",
                "New: Apple MagSafe Duo",
                "30-Day No-Hassle Returns",
                "Flash Sale — 40% Off Gaming",
                "Loyalty Points Every Order"
            };
            foreach (var t in tickers)
            {
                <span class="tick-item">@t<span class="tick-dot"></span></span>
            }
            // duplicate for seamless loop
            foreach (var t in tickers)
            {
                <span class="tick-item">@t<span class="tick-dot"></span></span>
            }
        }
    </div>
</div>

@* ══════════════════════════════════════════════
     SHOP BY CATEGORY
══════════════════════════════════════════════ *@
<section class="sec sec-alt">
    <div class="sec-hd">
        <div>
            <p class="sec-eye">Browse by Category</p>
            <h2 class="sec-ttl">SHOP<br />BY TYPE</h2>
        </div>
        <a href="/Categories" class="sec-more">All Categories →</a>
    </div>
    <div class="cat-grid reveal">
        @foreach (var cat in Model.Categories)
        {
            <div class="cat-card">
                <div class="cat-fig">@cat.Icon</div>
                <div class="cat-info">
                    <div class="cat-cnt">@cat.ItemCount Items</div>
                    <div class="cat-nm">@cat.Name</div>
                    <div class="cat-arr">→</div>
                </div>
            </div>
        }
    </div>
</section>

@* ══════════════════════════════════════════════
     FEATURED PRODUCTS
══════════════════════════════════════════════ *@
<section class="sec">
    <div class="sec-hd">
        <div>
            <p class="sec-eye">Handpicked For You</p>
            <h2 class="sec-ttl">FEATURED<br />PRODUCTS</h2>
        </div>
        <a href="#" class="sec-more">All Products →</a>
    </div>
    <div class="prod-grid reveal">
        @foreach (var p in Model.FeaturedProducts)
        {
            <div class="prod-card">
                <div class="prod-thumb">
                    <span>@p.Icon</span>
                    @if (!string.IsNullOrEmpty(p.BadgeClass))
                    {
                        <span class="p-badge badge-@p.BadgeClass">@p.BadgeText</span>
                    }
                </div>
                <div class="prod-body">
                    <p class="p-brand">@p.Brand</p>
                    <p class="p-name">@p.Name</p>
                    <p class="p-stars">
                        @for (int i = 0; i < p.Rating; i++)
                        {
                            <text>★</text>
                        }
                        @for (int i = p.Rating; i < 5; i++)
                        {
                            <text>☆</text>
                        }
                        <span class="p-rc">(@p.ReviewCount)</span>
                    </p>
                    <div class="p-foot">
                        <span class="p-price">
                            $@p.Price
                            @if (p.OldPrice.HasValue)
                            {
                                <span class="p-old">$@p.OldPrice.Value</span>
                            }
                        </span>
                        <button class="p-add">+</button>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@* ══════════════════════════════════════════════
     FLASH SALE BANNER
══════════════════════════════════════════════ *@
<div class="banner-wrap reveal">
    <div class="banner" data-sale-end="@Model.FlashSale.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
        <div>
            <p class="b-eye">Limited Time Offer</p>
            <h2 class="b-ttl" id="bTtl">
                @Html.Raw(Model.FlashSale.TitleLine1)<br />@Html.Raw(Model.FlashSale.TitleLine2)
            </h2>
            <p class="b-sub">@Model.FlashSale.Subtitle</p>
            <div class="b-count">
                <div class="c-blk"><span class="c-num" id="ch">08</span><span class="c-lbl">Hours</span></div>
                <span class="c-colon">:</span>
                <div class="c-blk"><span class="c-num" id="cm">42</span><span class="c-lbl">Mins</span></div>
                <span class="c-colon">:</span>
                <div class="c-blk"><span class="c-num" id="cs">17</span><span class="c-lbl">Secs</span></div>
            </div>
        </div>
        <button class="b-btn">Shop the Sale →</button>
    </div>
</div>

@* ══════════════════════════════════════════════
     BRAND PARTNERS
══════════════════════════════════════════════ *@
<div class="brands-sec reveal">
    <p class="brands-lbl">Official Partners &amp; Retailers</p>
    <div class="brands-row">
        @foreach (var brand in Model.PartnerBrands)
        {
            <span class="brand-nm">@brand</span>
        }
    </div>
</div>

@* ══════════════════════════════════════════════
     FEATURES / TRUST SIGNALS
══════════════════════════════════════════════ *@
<section class="sec sec-alt">
    <div class="feat-grid reveal">
        <div class="feat-card">
            <div class="feat-ico">🚚</div>
            <div class="feat-nm">Free Shipping</div>
            <p class="feat-txt">On all orders over $75. Same-day delivery available in select cities.</p>
        </div>
        <div class="feat-card">
            <div class="feat-ico">🔄</div>
            <div class="feat-nm">30-Day Returns</div>
            <p class="feat-txt">Full refund, no questions asked. Easy label printing from your account.</p>
        </div>
        <div class="feat-card">
            <div class="feat-ico">🔒</div>
            <div class="feat-nm">Secure Checkout</div>
            <p class="feat-txt">256-bit SSL. Card, Apple Pay, and PayPal accepted securely.</p>
        </div>
        <div class="feat-card">
            <div class="feat-ico">💬</div>
            <div class="feat-nm">24/7 Support</div>
            <p class="feat-txt">Real humans, any time. Chat, email, or call around the clock.</p>
        </div>
    </div>
</section>

@* ══════════════════════════════════════════════
     NEWSLETTER
══════════════════════════════════════════════ *@
<div class="nl-sec reveal">
    <p class="nl-eye">Stay in the Loop</p>
    <h2 class="nl-ttl" id="nlTtl">JOIN THE VOLTEX COMMUNITY</h2>
    <p class="nl-sub">Early access to drops, exclusive deals, and gear guides straight to your inbox.</p>
    <div class="nl-form">
        <input class="nl-in" type="email" placeholder="your@email.com" />
        <button class="nl-go">Subscribe</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
    <script>
        // Feed the server-calculated end time into your countdown
        (function () {
            const banner = document.querySelector('.banner');
            const endIso = banner?.dataset.saleEnd;
            if (endIso && typeof initCountdown === 'function') {
                initCountdown(new Date(endIso));
            }
        })();
    </script>
}