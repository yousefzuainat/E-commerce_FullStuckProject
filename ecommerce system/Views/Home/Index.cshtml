@model IEnumerable<ecommerce_system.Models.Proudect>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="flex flex-col gap-8">
    <!-- Hero Section -->
    <div class="relative overflow-hidden rounded-3xl glass-panel p-8 sm:p-12 shadow-2xl border border-white/10 bg-gradient-to-br from-surface-container to-[#0f141a]">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-600/20 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="max-w-xl">
                <h1 class="text-4xl sm:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400 mb-4 tracking-tight">
                    Manage Your <span class="text-primary">Inventory</span> With Precision
                </h1>
                <p class="text-lg text-gray-400 mb-8 font-medium">
                    High-performance e-commerce management system. Track products, monitor stock, and optimize your sales.
                </p>
                <div class="flex gap-4">
                    <a asp-controller="Proudects" asp-action="Create" class="inline-flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5">
                        <span class="material-symbols-outlined">add</span>
                        New Product
                    </a>
                    <a asp-controller="Proudects" asp-action="Index" class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white px-6 py-3 rounded-xl font-semibold transition-all">
                        <span class="material-symbols-outlined">inventory_2</span>
                        View All
                    </a>
                </div>
            </div>
            
            <!-- Quick Stats -->
            <div class="grid grid-cols-2 gap-4 w-full md:w-auto">
                <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm flex flex-col items-center justify-center min-w-[140px]">
                    <span class="material-symbols-outlined text-primary text-3xl mb-2">category</span>
                    <span class="text-3xl font-black text-white">@(Model?.Count() ?? 0)</span>
                    <span class="text-xs text-gray-400 uppercase tracking-wider font-bold mt-1">Total Products</span>
                </div>
                <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm flex flex-col items-center justify-center min-w-[140px]">
                    <span class="material-symbols-outlined text-green-400 text-3xl mb-2">trending_up</span>
                    <span class="text-3xl font-black text-white">Active</span>
                    <span class="text-xs text-gray-400 uppercase tracking-wider font-bold mt-1">System Status</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Products Grid Header -->
    <div class="flex items-center justify-between mt-4">
        <h2 class="text-2xl font-bold text-white flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">grid_view</span>
            Recent Products
        </h2>
        <a asp-controller="Proudects" asp-action="Index" class="text-sm font-medium text-primary hover:text-blue-400 flex items-center gap-1 transition-colors">
            View full inventory <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
    </div>

    <!-- Products Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var item in Model.Take(8))
            {
                <div class="group glass-panel rounded-2xl overflow-hidden flex flex-col hover:border-primary/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/10">
                    <!-- Image Container -->
                    <div class="relative aspect-[4/3] bg-white/5 overflow-hidden">
                        @if (item.Images != null && item.Images.Any())
                        {
                            <img src="@item.Images.FirstOrDefault().ImageUrl" alt="@item.Name" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" onerror="this.src='/images/placeholder.jpg'" />
                        }
                        else
                        {
                            <div class="w-full h-full flex flex-col items-center justify-center text-gray-500 gap-2">
                                <span class="material-symbols-outlined text-4xl opacity-50">image</span>
                                <span class="text-xs font-medium uppercase tracking-wider">No Image</span>
                            </div>
                        }
                        
                        @{ var activeDiscount = item.Discounts?.FirstOrDefault(d => d.Active)?.DiscountPercent ?? 0; }
                        @if (activeDiscount > 0)
                        {
                            <div class="absolute top-3 right-3 bg-red-500/90 text-white text-xs font-bold px-2 py-1 rounded-lg backdrop-blur-sm shadow-lg">
                                -@activeDiscount%
                            </div>
                        }
                    </div>

                    <!-- Content -->
                    <div class="p-5 flex flex-col flex-grow border-t border-white/5">
                        <div class="flex items-start justify-between gap-2 mb-2">
                            <h3 class="font-bold text-lg text-white truncate" title="@item.Name">@item.Name</h3>
                            <span class="font-black text-primary whitespace-nowrap">$@item.Price.ToString("0.00")</span>
                        </div>
                        
                        <p class="text-sm text-gray-400 line-clamp-2 mb-4 flex-grow">
                            @(string.IsNullOrEmpty(item.Description) ? "No description available." : item.Description)
                        </p>
                        
                        <!-- Actions -->
                        <div class="flex items-center gap-2 pt-4 border-t border-white/5">
                            <a asp-controller="Proudects" asp-action="Details" asp-route-id="@item.Id" class="flex-grow inline-flex items-center justify-center gap-1.5 bg-white/5 hover:bg-primary hover:text-white text-gray-300 py-2 rounded-lg text-sm font-medium transition-colors border border-white/5">
                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                                Details
                            </a>
                            <a asp-controller="Proudects" asp-action="Edit" asp-route-id="@item.Id" class="w-10 h-10 inline-flex items-center justify-center bg-white/5 hover:bg-amber-500/20 hover:text-amber-400 text-gray-300 rounded-lg transition-colors border border-white/5" title="Edit">
                                <span class="material-symbols-outlined text-[18px]">edit</span>
                            </a>
                            <a asp-controller="Proudects" asp-action="Delete" asp-route-id="@item.Id" class="w-10 h-10 inline-flex items-center justify-center bg-white/5 hover:bg-red-500/20 hover:text-red-400 text-gray-300 rounded-lg transition-colors border border-white/5" title="Delete">
                                <span class="material-symbols-outlined text-[18px]">delete</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="glass-panel rounded-3xl p-12 flex flex-col items-center justify-center text-center border border-white/5">
            <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-4xl text-gray-500">inventory_2</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">No Products Found</h3>
            <p class="text-gray-400 max-w-md mb-6">Your inventory is currently empty. Start adding products to manage them right here on the dashboard.</p>
            <a asp-controller="Proudects" asp-action="Create" class="inline-flex items-center gap-2 bg-primary hover:bg-blue-600 text-white px-6 py-2.5 rounded-xl font-semibold shadow-lg shadow-primary/20 transition-all">
                <span class="material-symbols-outlined">add</span>
                Add First Product
            </a>
        </div>
    }
</div>
