@using ecommerce_system.Models
@using Microsoft.EntityFrameworkCore
@inject ecommerce_system.Data.ApplicationDbContext _db
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";

    // Load testimonials inline — no extra controller action needed
    var allTestimonials = _db.Testimonials
        .Include(t => t.User)
        .OrderByDescending(t => t.CreatedAt)
        .ToList();

    var pending  = allTestimonials.Where(t => !t.IsApproved).ToList();
    var approved = allTestimonials.Where(t =>  t.IsApproved).ToList();

    string Initials(string? fullName, string? userName)
    {
        var name = fullName ?? userName ?? "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : name.Length >= 2 ? name[..2].ToUpperInvariant() : name.ToUpperInvariant();
    }
}

<!-- Welcome Header -->
<div class="mb-10">
    <h1 class="text-4xl font-black text-white">Welcome back, Admin 👋</h1>
    <p class="text-gray-400 mt-2">Here's what's happening in your store today.</p>
</div>

<!-- Quick Nav Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">

    <!-- Products Card -->
    <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Index"
       class="admin-card rounded-2xl p-6 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 group">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                <span class="material-symbols-outlined text-primary text-2xl">inventory_2</span>
            </div>
            <span class="text-xs text-gray-500 bg-white/5 px-2 py-1 rounded-lg">Manage</span>
        </div>
        <h2 class="text-xl font-black text-white group-hover:text-primary transition-colors">Products</h2>
        <p class="text-gray-400 text-sm mt-1">Add, edit, and manage your product catalog</p>
        <div class="flex items-center gap-1.5 mt-4 text-primary text-sm font-semibold">
            <span>Go to Products</span>
            <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </div>
    </a>

    <!-- Categories Card -->
    <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Index"
       class="admin-card rounded-2xl p-6 hover:border-admin-accent/40 hover:shadow-lg hover:shadow-admin-accent/5 transition-all duration-300 group">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-2xl bg-admin-accent/10 flex items-center justify-center group-hover:bg-admin-accent/20 transition-colors">
                <span class="material-symbols-outlined text-admin-accent text-2xl">category</span>
            </div>
            <span class="text-xs text-gray-500 bg-white/5 px-2 py-1 rounded-lg">Manage</span>
        </div>
        <h2 class="text-xl font-black text-white group-hover:text-admin-accent transition-colors">Categories</h2>
        <p class="text-gray-400 text-sm mt-1">Organize products into structured categories</p>
        <div class="flex items-center gap-1.5 mt-4 text-admin-accent text-sm font-semibold">
            <span>Go to Categories</span>
            <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </div>
    </a>

    <!-- Users Card -->
    <a asp-area="Admin" asp-controller="Admin" asp-action="Users"
       class="admin-card rounded-2xl p-6 hover:border-purple-500/40 hover:shadow-lg hover:shadow-purple-500/5 transition-all duration-300 group">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-2xl bg-purple-500/10 flex items-center justify-center group-hover:bg-purple-500/20 transition-colors">
                <span class="material-symbols-outlined text-purple-400 text-2xl">group</span>
            </div>
            <span class="text-xs text-gray-500 bg-white/5 px-2 py-1 rounded-lg">Manage</span>
        </div>
        <h2 class="text-xl font-black text-white group-hover:text-purple-400 transition-colors">Users</h2>
        <p class="text-gray-400 text-sm mt-1">Manage customer accounts and permissions</p>
        <div class="flex items-center gap-1.5 mt-4 text-purple-400 text-sm font-semibold">
            <span>Go to Users</span>
            <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </div>
    </a>

    <!-- Testimonials Summary Card -->
    <div class="admin-card rounded-2xl p-6 border-yellow-500/20 hover:border-yellow-500/40 hover:shadow-lg hover:shadow-yellow-500/5 transition-all duration-300 sm:col-span-2 lg:col-span-3">
        <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-yellow-500/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-yellow-400 text-2xl">rate_review</span>
                </div>
                <div>
                    <h2 class="text-xl font-black text-white">Testimonials</h2>
                    <p class="text-gray-400 text-sm">Approve or reject customer testimonials</p>
                </div>
            </div>
            <!-- Summary pills -->
            <div class="flex items-center gap-2">
                <span class="flex items-center gap-1.5 bg-yellow-500/10 text-yellow-400 text-xs font-bold px-3 py-1.5 rounded-lg">
                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span>
                    @pending.Count Pending
                </span>
                <span class="flex items-center gap-1.5 bg-green-500/10 text-green-400 text-xs font-bold px-3 py-1.5 rounded-lg">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                    @approved.Count Live
                </span>
            </div>
        </div>
    </div>
</div>

@* ════════════════════════════════════════════════════
   TESTIMONIALS — PENDING
════════════════════════════════════════════════════ *@
@if (pending.Any())
{
    <div class="admin-card rounded-2xl p-6 mb-6">
        <h2 class="text-sm font-black text-white uppercase tracking-widest mb-5 flex items-center gap-2">
            <span class="material-symbols-outlined text-yellow-400 text-lg">pending</span>
            Pending Approval
            <span class="ml-1 bg-yellow-500/15 text-yellow-400 text-xs font-bold px-2 py-0.5 rounded-md">@pending.Count</span>
        </h2>

        <div class="flex flex-col gap-4">
            @foreach (var t in pending)
            {
                var initials = Initials(t.User?.FullName, t.User?.UserName);
                var authorName = t.User?.FullName ?? t.User?.UserName ?? "Unknown";
                <div class="flex flex-col sm:flex-row sm:items-start gap-4 p-4 rounded-xl bg-white/[0.03] border border-white/[0.06] hover:border-yellow-500/20 transition-colors">

                    <!-- Avatar -->
                    <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center text-sm font-black text-black flex-shrink-0">
                        @initials
                    </div>

                    <!-- Content -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1 flex-wrap">
                            <span class="text-white font-bold text-sm">@authorName</span>
                            <!-- Stars -->
                            <span class="text-yellow-400 text-xs tracking-wider">
                                @for (int i = 1; i <= 5; i++)
                                { @(i <= t.Rating ? "★" : "☆") }
                            </span>
                            <span class="text-gray-500 text-xs ml-auto">@t.CreatedAt.ToString("MMM dd, yyyy · HH:mm")</span>
                        </div>
                        <p class="text-gray-300 text-sm leading-relaxed line-clamp-3">@t.Content</p>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-2 flex-shrink-0 sm:flex-col lg:flex-row">
                        <form asp-controller="Testimonials" asp-action="Approve" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit"
                                    class="admin-btn-primary text-xs px-4 py-2 flex items-center gap-1.5 whitespace-nowrap">
                                <span class="material-symbols-outlined text-sm">check_circle</span>
                                Approve
                            </button>
                        </form>
                        <form asp-controller="Testimonials" asp-action="Reject" method="post"
                              onsubmit="return confirm('Reject and delete this testimonial?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit"
                                    class="admin-btn-secondary text-xs px-4 py-2 flex items-center gap-1.5 whitespace-nowrap hover:border-red-500/50 hover:text-red-400 transition-colors">
                                <span class="material-symbols-outlined text-sm">cancel</span>
                                Reject
                            </button>
                        </form>
                    </div>

                </div>
            }
        </div>
    </div>
}
else
{
    <div class="admin-card rounded-2xl p-6 mb-6">
        <h2 class="text-sm font-black text-white uppercase tracking-widest mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-yellow-400 text-lg">pending</span>
            Pending Approval
        </h2>
        <div class="flex flex-col items-center justify-center py-8 text-center">
            <span class="material-symbols-outlined text-4xl text-gray-600 mb-3">task_alt</span>
            <p class="text-gray-400 text-sm">No pending testimonials. You're all caught up!</p>
        </div>
    </div>
}

@* ════════════════════════════════════════════════════
   TESTIMONIALS — LIVE / APPROVED
════════════════════════════════════════════════════ *@
<div class="admin-card rounded-2xl p-6 mb-10">
    <h2 class="text-sm font-black text-white uppercase tracking-widest mb-5 flex items-center gap-2">
        <span class="material-symbols-outlined text-green-400 text-lg">verified</span>
        Live on Homepage
        <span class="ml-1 bg-green-500/15 text-green-400 text-xs font-bold px-2 py-0.5 rounded-md">@approved.Count</span>
    </h2>

    @if (!approved.Any())
    {
        <div class="flex flex-col items-center justify-center py-8 text-center">
            <span class="material-symbols-outlined text-4xl text-gray-600 mb-3">reviews</span>
            <p class="text-gray-400 text-sm">No approved testimonials yet. Approve some above to display them on the homepage.</p>
        </div>
    }
    else
    {
        <div class="flex flex-col gap-3">
            @foreach (var t in approved)
            {
                var initials = Initials(t.User?.FullName, t.User?.UserName);
                var authorName = t.User?.FullName ?? t.User?.UserName ?? "Unknown";
                <div class="flex flex-col sm:flex-row sm:items-start gap-4 p-4 rounded-xl bg-white/[0.03] border border-white/[0.06] hover:border-green-500/20 transition-colors opacity-80 hover:opacity-100">

                    <!-- Avatar -->
                    <div class="w-10 h-10 rounded-xl bg-green-500/20 border border-green-500/30 flex items-center justify-center text-sm font-black text-green-400 flex-shrink-0">
                        @initials
                    </div>

                    <!-- Content -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1 flex-wrap">
                            <span class="text-white font-bold text-sm">@authorName</span>
                            <span class="text-yellow-400 text-xs tracking-wider">
                                @for (int i = 1; i <= 5; i++)
                                { @(i <= t.Rating ? "★" : "☆") }
                            </span>
                            <span class="flex items-center gap-1 bg-green-500/10 text-green-400 text-xs font-bold px-2 py-0.5 rounded-md">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                                LIVE
                            </span>
                            <span class="text-gray-500 text-xs ml-auto">@t.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <p class="text-gray-400 text-sm leading-relaxed line-clamp-2">@t.Content</p>
                    </div>

                    <!-- Remove -->
                    <form asp-controller="Testimonials" asp-action="Reject" method="post"
                          onsubmit="return confirm('Remove this live testimonial from the homepage?')"
                          class="flex-shrink-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@t.Id" />
                        <button type="submit"
                                class="admin-btn-secondary text-xs px-4 py-2 flex items-center gap-1.5 whitespace-nowrap hover:border-red-500/50 hover:text-red-400 transition-colors">
                            <span class="material-symbols-outlined text-sm">delete</span>
                            Remove
                        </button>
                    </form>

                </div>
            }
        </div>
    }
</div>

<!-- Quick Actions -->
<div class="admin-card rounded-2xl p-6">
    <h2 class="text-sm font-black text-white uppercase tracking-widest mb-5 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-lg">bolt</span>
        Quick Actions
    </h2>
    <div class="flex flex-wrap gap-3">
        <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Create" class="admin-btn-primary">
            <span class="material-symbols-outlined text-base">add</span>
            New Product
        </a>
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Create" class="admin-btn-secondary">
            <span class="material-symbols-outlined text-base">add</span>
            New Category
        </a>
    </div>
</div>
