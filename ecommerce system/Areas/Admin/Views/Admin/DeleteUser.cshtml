@model ecommerce_system.Models.AppliactionUser
@{
    ViewData["Title"] = "Delete User";
    Layout = "_AdminLayout";
}

<div class="max-w-xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
        <a asp-area="Admin" asp-controller="Admin" asp-action="Users"
           class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white transition-all">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-3xl font-black text-white">Delete User</h1>
            <p class="text-red-400 text-sm mt-0.5">This action cannot be undone</p>
        </div>
    </div>

    <div class="admin-card rounded-2xl border border-red-500/30 bg-red-500/5 p-5 mb-6 flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-red-400 text-2xl">warning</span>
        </div>
        <div>
            <p class="font-bold text-white">Are you sure you want to delete this user?</p>
            <p class="text-gray-400 text-sm mt-0.5">All data associated with this account will be removed.</p>
        </div>
    </div>

    <div class="admin-card rounded-2xl p-6 mb-6">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center font-bold text-white text-xl shrink-0">
                @(Model.FullName?.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "U")
            </div>
            <div>
                <p class="font-bold text-white text-lg">@(Model.FullName ?? "No Name")</p>
                <p class="text-sm text-gray-400">@Model.Email</p>
                <p class="text-xs text-gray-600 mt-1">ID: @Model.Id</p>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <form asp-area="Admin" asp-controller="Admin" asp-action="DeleteUser" method="post" class="flex-1">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="admin-btn-danger w-full justify-center py-3 text-base">
                <span class="material-symbols-outlined">delete_forever</span>
                Yes, Delete User
            </button>
        </form>
        <a asp-area="Admin" asp-controller="Admin" asp-action="Users" class="admin-btn-secondary flex-1 justify-center py-3 text-base">
            <span class="material-symbols-outlined">close</span>
            Cancel
        </a>
    </div>
</div>
