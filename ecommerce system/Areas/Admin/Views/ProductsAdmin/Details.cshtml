@model ecommerce_system.Models.Proudect
@{
    ViewData["Title"] = "Product Details";
    Layout = "_AdminLayout";
    var activeDiscount = Model.Discounts?.FirstOrDefault(d => d.Active);
    var discountedPrice = activeDiscount != null ? Model.Price * (1 - activeDiscount.DiscountPercent / 100) : Model.Price;
}

<!-- Page Header -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
    <div>
        <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Index" class="inline-flex items-center gap-1.5 text-gray-400 hover:text-white text-sm transition-colors mb-2">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Back to Products
        </a>
        <h1 class="text-3xl font-black text-white">Product Details</h1>
    </div>
    <div class="flex items-center gap-3">
        <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Edit" asp-route-id="@Model.Id" class="admin-btn-primary">
            <span class="material-symbols-outlined text-base">edit</span>
            Edit Product
        </a>
        <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Delete" asp-route-id="@Model.Id" class="admin-btn-danger">
            <span class="material-symbols-outlined text-base">delete</span>
            Delete
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: Images -->
    <div class="lg:col-span-1 space-y-4">
        <!-- Main Image -->
        <div class="admin-card rounded-2xl overflow-hidden aspect-square">
            @if (Model.Images != null && Model.Images.Any())
            {
                <img id="main-image" src="@Model.Images.First().ImageUrl" alt="@Model.Name" class="w-full h-full object-cover" />
            }
            else if (!string.IsNullOrEmpty(Model.Img))
            {
                <img src="@Model.Img" alt="@Model.Name" class="w-full h-full object-cover" />
            }
            else
            {
                <div class="w-full h-full flex flex-col items-center justify-center bg-white/3">
                    <span class="material-symbols-outlined text-6xl text-gray-600">image</span>
                    <p class="text-gray-600 text-sm mt-2">No image</p>
                </div>
            }
        </div>

        <!-- Thumbnails -->
        @if (Model.Images != null && Model.Images.Count() > 1)
        {
            <div class="grid grid-cols-4 gap-2">
                @foreach (var img in Model.Images)
                {
                    <button onclick="document.getElementById('main-image').src='@img.ImageUrl'"
                            class="aspect-square rounded-xl overflow-hidden border-2 border-white/10 hover:border-primary transition-all">
                        <img src="@img.ImageUrl" alt="" class="w-full h-full object-cover" />
                    </button>
                }
            </div>
        }
    </div>

    <!-- Right: Details -->
    <div class="lg:col-span-2 space-y-6">
        <!-- Product Info Card -->
        <div class="admin-card rounded-2xl p-6">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                    <h2 class="text-2xl font-black text-white">@Model.Name</h2>
                    <span class="inline-flex items-center gap-1.5 text-xs bg-primary/10 text-primary px-3 py-1.5 rounded-full font-semibold border border-primary/20 mt-2">
                        <span class="material-symbols-outlined text-xs">category</span>
                        @(Model.Category?.Name ?? "Uncategorized")
                    </span>
                </div>
                <div class="text-right">
                    @if (activeDiscount != null)
                    {
                        <p class="text-gray-400 line-through text-sm">$@Model.Price.ToString("0.00")</p>
                        <p class="text-3xl font-black text-green-400">$@discountedPrice.ToString("0.00")</p>
                        <span class="inline-block text-xs bg-green-500/10 text-green-400 px-2 py-0.5 rounded-full border border-green-500/20 font-bold">
                            -@activeDiscount.DiscountPercent% OFF
                        </span>
                    }
                    else
                    {
                        <p class="text-3xl font-black text-white">$@Model.Price.ToString("0.00")</p>
                    }
                </div>
            </div>

            <div class="border-t border-white/10 pt-4">
                <p class="admin-label">Description</p>
                <p class="text-gray-300 leading-relaxed">@Model.Description</p>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-3 gap-4">
            <div class="admin-card rounded-2xl p-4 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1">Product ID</p>
                <p class="text-xl font-black text-primary">#@Model.Id</p>
            </div>
            <div class="admin-card rounded-2xl p-4 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1">Images</p>
                <p class="text-xl font-black text-white">@(Model.Images?.Count ?? 0)</p>
            </div>
            <div class="admin-card rounded-2xl p-4 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1">Reviews</p>
                <p class="text-xl font-black text-white">@(Model.Reviews?.Count ?? 0)</p>
            </div>
        </div>

        <!-- Discount Info -->
        @if (activeDiscount != null)
        {
            <div class="admin-card rounded-2xl p-5 border border-green-500/20 bg-green-500/5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-green-400 text-xl">local_offer</span>
                    </div>
                    <div>
                        <p class="font-semibold text-white">Active Discount: @activeDiscount.DiscountPercent%</p>
                        <p class="text-sm text-gray-400">Customers save $@((Model.Price - discountedPrice).ToString("0.00")) per unit</p>
                    </div>
                </div>
            </div>
        }

        <!-- Reviews -->
        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            <div class="admin-card rounded-2xl p-6">
                <h3 class="text-sm font-black text-white uppercase tracking-widest mb-4">Customer Reviews (@Model.Reviews.Count)</h3>
                <div class="space-y-3">
                    @foreach (var review in Model.Reviews.Take(5))
                    {
                        <div class="bg-white/3 rounded-xl p-4">
                            <p class="text-sm text-gray-300">@review.comment</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
