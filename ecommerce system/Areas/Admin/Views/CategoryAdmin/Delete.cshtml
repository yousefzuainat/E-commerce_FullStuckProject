@model ecommerce_system.Models.Category
@{
    ViewData["Title"] = "Delete Category";
    Layout = "_AdminLayout";
}

<div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Index" class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white transition-all">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-3xl font-black text-white">Delete Category</h1>
            <p class="text-red-400 text-sm mt-0.5">This action cannot be undone</p>
        </div>
    </div>

    <!-- Warning -->
    <div class="admin-card rounded-2xl border border-red-500/30 bg-red-500/5 p-6 mb-6">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-red-400 text-2xl">warning</span>
            </div>
            <div>
                <h2 class="text-lg font-bold text-white">Confirm Deletion</h2>
                <p class="text-gray-400 text-sm">Are you sure you want to delete this category?</p>
            </div>
        </div>
    </div>

    @if (Model.Proudects != null && Model.Proudects.Any())
    {
        <div class="admin-card rounded-2xl border border-admin-accent/30 bg-admin-accent/5 p-5 mb-6">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-admin-accent text-2xl">inventory_2</span>
                <div>
                    <p class="font-semibold text-white text-sm">This category has <span class="text-admin-accent">@Model.Proudects.Count products</span></p>
                    <p class="text-gray-400 text-xs mt-0.5">These products will lose their category assignment</p>
                </div>
            </div>
        </div>
    }

    <!-- Category Preview -->
    <div class="admin-card rounded-2xl p-6 mb-6">
        <div class="flex items-center gap-5">
            @if (!string.IsNullOrEmpty(Model.Img))
            {
                <img src="/images/Categories/@Model.Img" alt="@Model.Name" class="w-20 h-20 rounded-2xl object-cover border border-white/10 shrink-0" />
            }
            else
            {
                <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-3xl text-gray-600">category</span>
                </div>
            }
            <div>
                <h3 class="text-xl font-bold text-white">@Model.Name</h3>
                <div class="flex items-center gap-3 mt-2">
                    <span class="text-xs text-gray-500">ID: #@Model.Id</span>
                    <span class="inline-flex items-center gap-1 text-xs bg-admin-accent/10 text-admin-accent px-2.5 py-1 rounded-full border border-admin-accent/20 font-semibold">
                        <span class="material-symbols-outlined text-xs">inventory_2</span>
                        @(Model.Proudects?.Count ?? 0) products
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
        <form asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Delete" method="post" class="flex-1">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="admin-btn-danger w-full justify-center py-3 text-base">
                <span class="material-symbols-outlined">delete_forever</span>
                Yes, Delete Category
            </button>
        </form>
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Index" class="admin-btn-secondary flex-1 justify-center py-3 text-base">
            <span class="material-symbols-outlined">close</span>
            Cancel
        </a>
    </div>
</div>
