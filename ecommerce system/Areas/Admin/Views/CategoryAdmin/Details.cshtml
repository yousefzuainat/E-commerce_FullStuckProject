@model ecommerce_system.Models.Category
@{
    ViewData["Title"] = "Category Details";
    Layout = "_AdminLayout";
}

<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
    <div>
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Index" class="inline-flex items-center gap-1.5 text-gray-400 hover:text-white text-sm transition-colors mb-2">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Back to Categories
        </a>
        <h1 class="text-3xl font-black text-white">@Model.Name</h1>
    </div>
    <div class="flex items-center gap-3">
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Edit" asp-route-id="@Model.Id" class="admin-btn-primary">
            <span class="material-symbols-outlined text-base">edit</span>
            Edit
        </a>
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Delete" asp-route-id="@Model.Id" class="admin-btn-danger">
            <span class="material-symbols-outlined text-base">delete</span>
            Delete
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Category Image & Info -->
    <div class="space-y-5">
        <div class="admin-card rounded-2xl overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.Img))
            {
                <img src="/images/Categories/@Model.Img" alt="@Model.Name" class="w-full aspect-square object-cover" />
            }
            else
            {
                <div class="w-full aspect-square bg-white/3 flex flex-col items-center justify-center">
                    <span class="material-symbols-outlined text-6xl text-gray-600">category</span>
                    <p class="text-gray-600 text-sm mt-2">No image</p>
                </div>
            }
        </div>

        <div class="admin-card rounded-2xl p-5">
            <h3 class="text-xs font-black text-gray-500 uppercase tracking-widest mb-4">Category Info</h3>
            <div class="space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-400">ID</span>
                    <span class="text-sm font-bold text-primary">#@Model.Id</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-400">Name</span>
                    <span class="text-sm font-bold text-white">@Model.Name</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-400">Products</span>
                    <span class="text-sm font-bold text-admin-accent">@(Model.Proudects?.Count ?? 0)</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-400">Has Image</span>
                    <span class="text-sm font-bold @(!string.IsNullOrEmpty(Model.Img) ? "text-green-400" : "text-gray-600")">
                        @(!string.IsNullOrEmpty(Model.Img) ? "Yes" : "No")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Products List -->
    <div class="lg:col-span-2">
        <div class="admin-card rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-white/10 flex items-center justify-between">
                <h2 class="font-black text-white text-sm uppercase tracking-widest">Products in this Category</h2>
                <span class="text-xs bg-primary/10 text-primary px-3 py-1 rounded-full font-bold border border-primary/20">
                    @(Model.Proudects?.Count ?? 0) items
                </span>
            </div>

            @if (Model.Proudects == null || !Model.Proudects.Any())
            {
                <div class="flex flex-col items-center justify-center py-16 text-center">
                    <span class="material-symbols-outlined text-5xl text-gray-700 mb-3">inventory_2</span>
                    <p class="text-gray-500 font-semibold">No products in this category</p>
                    <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Create" class="admin-btn-primary mt-4 text-sm">
                        <span class="material-symbols-outlined text-base">add</span>
                        Add Product
                    </a>
                </div>
            }
            else
            {
                <div class="divide-y divide-white/5">
                    @foreach (var product in Model.Proudects)
                    {
                        <div class="flex items-center gap-4 px-6 py-4 hover:bg-white/3 transition-colors group">
                            @if (product.Images != null && product.Images.Any())
                            {
                                <img src="@product.Images.First().ImageUrl" alt="@product.Name"
                                     class="w-12 h-12 rounded-xl object-cover border border-white/10 shrink-0" />
                            }
                            else if (!string.IsNullOrEmpty(product.Img))
                            {
                                <img src="@product.Img" alt="@product.Name"
                                     class="w-12 h-12 rounded-xl object-cover border border-white/10 shrink-0" />
                            }
                            else
                            {
                                <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-gray-600">image</span>
                                </div>
                            }
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-white text-sm truncate">@product.Name</p>
                                <p class="text-xs text-primary font-bold">$@product.Price.ToString("0.00")</p>
                            </div>
                            <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Details" asp-route-id="@product.Id"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 hover:text-primary hover:bg-primary/10 transition-all">
                                    <span class="material-symbols-outlined text-base">visibility</span>
                                </a>
                                <a asp-area="Admin" asp-controller="ProductsAdmin" asp-action="Edit" asp-route-id="@product.Id"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 hover:text-admin-accent hover:bg-admin-accent/10 transition-all">
                                    <span class="material-symbols-outlined text-base">edit</span>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
