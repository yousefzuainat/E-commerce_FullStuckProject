@model IEnumerable<ecommerce_system.Models.Category>
@{
    ViewData["Title"] = "Categories Management";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-black text-white">Categories</h1>
        <p class="text-gray-400 text-sm mt-1">Organize your product categories</p>
    </div>
    <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Create" class="admin-btn-primary">
        <span class="material-symbols-outlined text-base">add</span>
        Add Category
    </a>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-8">
    <div class="admin-card p-4 rounded-2xl">
        <p class="text-xs text-gray-500 uppercase tracking-widest font-bold">Total Categories</p>
        <p class="text-3xl font-black text-white mt-1">@ViewBag.TotalCategories</p>
    </div>
    <div class="admin-card p-4 rounded-2xl">
        <p class="text-xs text-gray-500 uppercase tracking-widest font-bold">Total Products</p>
        <p class="text-3xl font-black text-primary mt-1">@Model.Sum(c => c.Proudects?.Count ?? 0)</p>
    </div>
    <div class="admin-card p-4 rounded-2xl hidden sm:block">
        <p class="text-xs text-gray-500 uppercase tracking-widest font-bold">With Images</p>
        <p class="text-3xl font-black text-admin-accent mt-1">@Model.Count(c => !string.IsNullOrEmpty(c.Img))</p>
    </div>
</div>

<!-- Search -->
<div class="admin-card rounded-2xl p-5 mb-6">
    <form method="get" asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Index" class="flex gap-3">
        <div class="relative flex-1">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-lg">search</span>
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Search categories..."
                   class="admin-input pl-10" />
        </div>
        <button type="submit" class="admin-btn-primary whitespace-nowrap">
            <span class="material-symbols-outlined text-base">search</span>
            Search
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()))
        {
            <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Index" class="admin-btn-secondary whitespace-nowrap">
                <span class="material-symbols-outlined text-base">close</span>
                Clear
            </a>
        }
    </form>
</div>

<!-- Categories Grid -->
@if (!Model.Any())
{
    <div class="admin-card rounded-2xl flex flex-col items-center justify-center py-20 text-center">
        <div class="w-20 h-20 rounded-3xl bg-white/5 flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-4xl text-gray-600">category</span>
        </div>
        <h3 class="text-xl font-bold text-gray-400">No categories found</h3>
        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Create" class="admin-btn-primary mt-6">
            <span class="material-symbols-outlined text-base">add</span>
            Create First Category
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        @foreach (var item in Model)
        {
            <div class="admin-card rounded-2xl overflow-hidden group hover:border-primary/30 transition-all duration-300 hover:shadow-lg hover:shadow-primary/5">
                <!-- Category Image -->
                <div class="relative aspect-video overflow-hidden bg-white/3">
                    @if (!string.IsNullOrEmpty(item.Img))
                    {
                        <img src="/images/Categories/@item.Img" alt="@item.Name"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                    }
                    else
                    {
                        <div class="w-full h-full flex flex-col items-center justify-center">
                            <span class="material-symbols-outlined text-4xl text-gray-600">category</span>
                        </div>
                    }
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                    <div class="absolute bottom-3 left-3">
                        <span class="inline-flex items-center gap-1 bg-white/10 backdrop-blur-sm text-white text-xs px-2.5 py-1 rounded-full border border-white/20 font-semibold">
                            <span class="material-symbols-outlined text-xs">inventory_2</span>
                            @(item.Proudects?.Count ?? 0) products
                        </span>
                    </div>
                </div>

                <!-- Category Info -->
                <div class="p-4">
                    <h3 class="font-bold text-white text-base mb-1">@item.Name</h3>
                    <p class="text-xs text-gray-500">Category ID: #@item.Id</p>

                    <!-- Actions -->
                    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-white/5">
                        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Details" asp-route-id="@item.Id"
                           class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-semibold text-gray-400 hover:text-primary hover:bg-primary/10 transition-all border border-white/10 hover:border-primary/30">
                            <span class="material-symbols-outlined text-sm">visibility</span>
                            View
                        </a>
                        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Edit" asp-route-id="@item.Id"
                           class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-semibold text-gray-400 hover:text-admin-accent hover:bg-admin-accent/10 transition-all border border-white/10 hover:border-admin-accent/30">
                            <span class="material-symbols-outlined text-sm">edit</span>
                            Edit
                        </a>
                        <a asp-area="Admin" asp-controller="CategoryAdmin" asp-action="Delete" asp-route-id="@item.Id"
                           class="w-9 h-9 flex items-center justify-center rounded-xl text-gray-400 hover:text-red-400 hover:bg-red-500/10 transition-all border border-white/10 hover:border-red-500/30">
                            <span class="material-symbols-outlined text-sm">delete</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
