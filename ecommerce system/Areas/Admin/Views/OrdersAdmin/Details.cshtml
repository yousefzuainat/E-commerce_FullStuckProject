@model ecommerce_system.Models.order
@{
    ViewData["Title"] = "Order Details";
    Layout = "_AdminLayout";
}

<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-black text-white">Order Details</h1>
        <p class="text-gray-400 text-sm mt-1">Details for Order #@Model.Id</p>
    </div>
    <a asp-action="Index" class="admin-btn-secondary">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Back to Orders
    </a>
</div>

<div class="admin-card rounded-2xl mb-8 overflow-hidden">
    <div class="px-6 py-5 border-b border-white/5 bg-white/2">
        <h3 class="text-lg font-bold text-white">Order Information</h3>
    </div>
    <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div>
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Order ID</p>
                    <p class="text-white font-bold text-lg">#@Model.Id</p>
                </div>
                <div>
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Customer</p>
                    <div class="flex items-center gap-3 mt-2">
                        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary shrink-0">
                            <span class="material-symbols-outlined text-xl">person</span>
                        </div>
                        <div>
                            <p class="font-semibold text-white text-sm">@(Model.User?.FullName ?? Model.User?.UserName ?? "Anonymous")</p>
                            <p class="text-xs text-gray-500">@Model.User?.Email</p>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    var parts = Model.Address.Split('|');
                    var gov = parts.ElementAtOrDefault(0)?.Trim() ?? "";
                    var street = parts.ElementAtOrDefault(1)?.Trim() ?? "";
                    var phone = parts.ElementAtOrDefault(2)?.Trim() ?? "";

                    <div>
                        <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Shipping Information</p>
                        <div class="bg-white/2 border border-white/5 rounded-xl p-4 mt-2 space-y-2">
                            <p class="text-white text-sm"><span class="text-gray-400">Governorate:</span> <strong class="text-primary font-bold">@gov</strong></p>
                            <p class="text-white text-sm"><span class="text-gray-400">Street / Details:</span> @street</p>
                            @if (!string.IsNullOrEmpty(phone))
                            {
                                <p class="text-white text-sm"><span class="text-gray-400">Receiver Phone:</span> @phone</p>
                            }
                        </div>
                    </div>
                }
                <div>
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Total Amount</p>
                    <p class="text-3xl font-black text-primary mt-1">@Model.tootal_amount.ToString("C")</p>
                </div>
            </div>

            <div class="space-y-6 bg-white/2 p-6 rounded-xl border border-white/5">
                <div>
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-3">Current Status</p>
                    @{
                        // FIX: Explicitly compare against the OrderStatus enum types
                        var statusClass = Model.Status == ecommerce_system.Models.OrderStatus.Completed ? "bg-green-500/10 text-green-400 border-green-500/20" :
                                          Model.Status == ecommerce_system.Models.OrderStatus.Pending ? "bg-yellow-500/10 text-yellow-400 border-yellow-500/20" :
                                          Model.Status == ecommerce_system.Models.OrderStatus.Cancelled ? "bg-red-500/10 text-red-400 border-red-500/20" :
                                          "bg-blue-500/10 text-blue-400 border-blue-500/20";
                    }
                    <span class="inline-flex items-center gap-1.5 text-sm px-4 py-2 rounded-full font-bold border @statusClass">
                        @Model.Status
                    </span>
                </div>
                <div class="pt-4 border-t border-white/5">
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-3">Update Status</p>
                    <form asp-action="UpdateStatus" method="post" class="flex flex-col sm:flex-row gap-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="status" class="admin-input flex-1" asp-items="Html.GetEnumSelectList<ecommerce_system.Models.OrderStatus>()">
                            <option value="">-- Select Status --</option>
                        </select>
                        <button type="submit" class="admin-btn-primary whitespace-nowrap">
                            <span class="material-symbols-outlined text-base">update</span>
                            Update
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="admin-card rounded-2xl overflow-hidden">
    <div class="px-6 py-5 border-b border-white/5 bg-white/2">
        <h3 class="text-lg font-bold text-white">Order Items</h3>
    </div>
    
    @if (Model.OrderItems != null && Model.OrderItems.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-white/10 bg-white/2">
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-6 py-4">Product</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Unit Price</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Quantity</th>
                        <th class="text-right text-xs font-black text-gray-500 uppercase tracking-widest px-6 py-4">Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr class="hover:bg-white/3 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                                        <span class="material-symbols-outlined text-gray-500 text-lg">inventory_2</span>
                                    </div>
                                    <p class="font-semibold text-white text-sm">@(item.Proudect?.Name ?? "Unknown Product")</p>
                                </div>
                            </td>
                            <td class="px-4 py-4">
                                <p class="text-gray-300 text-sm">@item.UnitPrice.ToString("C")</p>
                            </td>
                            <td class="px-4 py-4">
                                <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-1 rounded-md bg-white/5 text-gray-300 text-sm font-bold">
                                    x@(item.Quantity)
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <p class="font-bold text-white text-sm">@((item.Quantity * item.UnitPrice).ToString("C"))</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-16 text-center">
            <span class="material-symbols-outlined text-4xl text-gray-600 mb-3">shopping_cart</span>
            <p class="text-gray-400 text-sm">No items found for this order.</p>
        </div>
    }
</div>