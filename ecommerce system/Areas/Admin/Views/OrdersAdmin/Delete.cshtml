
@model ecommerce_system.Models.order

@{
    ViewData["Title"] = "Delete Order";
    Layout = "_AdminLayout";
}

<div class="flex items-center gap-4 mb-8">
    <a asp-action="Index" class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white transition-all">
        <span class="material-symbols-outlined">arrow_back</span>
    </a>
    <div>
        <h1 class="text-3xl font-black text-white">Delete Order</h1>
        <p class="text-gray-400 text-sm mt-0.5">Order #@Model.Id</p>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <div class="admin-card rounded-2xl overflow-hidden border border-red-500/30">
        <div class="px-6 py-5 bg-red-500/10 border-b border-red-500/20 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500 text-2xl">warning</span>
            <div>
                <h3 class="text-lg font-bold text-red-400">Confirm Deletion</h3>
                <p class="text-sm text-red-400/80 mt-0.5">Are you sure you want to delete Order #@Model.Id?</p>
            </div>
        </div>

        <div class="p-6">
            <div class="space-y-6">
                <div>
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Order ID</p>
                    <p class="text-white font-bold text-lg">#@Model.Id</p>
                </div>
                <div>
                    <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Customer</p>
                    <div class="flex items-center gap-3 mt-2">
                        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary shrink-0">
                            <span class="material-symbols-outlined text-xl">person</span>
                        </div>
                        <div>
                            <p class="font-semibold text-white text-sm">@(Model.User?.FullName ?? Model.User?.UserName ?? "Anonymous")</p>
                            <p class="text-xs text-gray-500">@Model.User?.Email</p>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Total Amount</p>
                        <p class="text-2xl font-black text-primary mt-1">@Model.tootal_amount.ToString("C")</p>
                    </div>
                    <div>
                        <p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-1">Status</p>
                        @{
                            // FIX: Updated to evaluate explicitly against the OrderStatus enum values
                            var statusClass = Model.Status == ecommerce_system.Models.OrderStatus.Completed ? "bg-green-500/10 text-green-400 border-green-500/20" :
                                              Model.Status == ecommerce_system.Models.OrderStatus.Pending ? "bg-yellow-500/10 text-yellow-400 border-yellow-500/20" :
                                              Model.Status == ecommerce_system.Models.OrderStatus.Cancelled ? "bg-red-500/10 text-red-400 border-red-500/20" :
                                              "bg-blue-500/10 text-blue-400 border-blue-500/20";
                        }
                        <span class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 mt-1 rounded-full font-bold border @statusClass">
                            @Model.Status
                        </span>
                    </div>
                </div>
            </div>
            
            <div class="mt-8 pt-6 border-t border-white/5">
                <form asp-action="Delete" method="post" class="flex flex-col sm:flex-row gap-3">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-red-500/20 hover:bg-red-500 text-red-400 hover:text-white border border-red-500/30 font-semibold rounded-xl transition-all">
                        <span class="material-symbols-outlined">delete_forever</span>
                        Yes, Delete Order
                    </button>
                    <a asp-action="Index" class="admin-btn-secondary flex-1 justify-center py-3">
                        <span class="material-symbols-outlined">close</span>
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
