@model ecommerce_system.Models.order

@{
    ViewData["Title"] = "Delete Order";
}

<div class="container-fluid px-4 py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-4 text-danger">Delete Order</h1>
            <p class="text-muted mb-2">Are you sure you want to delete Order #@Model.Id?</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-secondary">Back to Orders</a>
        </div>
    </div>

    <div class="card shadow-sm border-danger rounded-3 mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Order Information</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Order ID</dt>
                <dd class="col-sm-9">#@Model.Id</dd>

                <dt class="col-sm-3">Customer</dt>
                <dd class="col-sm-9">@(Model.User?.UserName ?? "Anonymous")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @Model.Status
                </dd>

                <dt class="col-sm-3">Total Amount</dt>
                <dd class="col-sm-9 fw-bold">@Model.tootal_amount.ToString("C")</dd>
            </dl>
        </div>
        <div class="card-footer">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Yes, Delete Order</button>
            </form>
        </div>
    </div>
</div>
