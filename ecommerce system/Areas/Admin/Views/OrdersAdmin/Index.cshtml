@model IEnumerable<ecommerce_system.Models.order>
@{
    ViewData["Title"] = "Orders Management";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-black text-white">Orders Management</h1>
        <p class="text-gray-400 text-sm mt-1">Manage and track customer orders</p>
    </div>
</div>

<!-- Filters -->
<div class="admin-card rounded-2xl p-5 mb-6">
    <form asp-action="Index" method="get" class="flex flex-col sm:flex-row items-end sm:items-center gap-3">
        <div class="flex flex-col w-full sm:w-auto">
            <label for="userId" class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Filter by User</label>
            <select name="userId" id="userId" asp-items="ViewBag.UserId" class="admin-input sm:w-64">
                <option value="">All Users</option>
            </select>
        </div>
        <button type="submit" class="admin-btn-primary whitespace-nowrap mt-2 sm:mt-0">
            <span class="material-symbols-outlined text-base">filter_list</span>
            Filter
        </button>
    </form>
</div>

<!-- Orders Table -->
<div class="admin-card rounded-2xl overflow-hidden">
    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-20 h-20 rounded-3xl bg-white/5 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-4xl text-gray-600">receipt_long</span>
            </div>
            <h3 class="text-xl font-bold text-gray-400">No orders found</h3>
            <p class="text-gray-600 text-sm mt-1">Try adjusting your user filter.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-white/10 bg-white/2">
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-6 py-4">Order ID</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Customer</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Governorate</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Date</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Total Amount</th>
                        <th class="text-left text-xs font-black text-gray-500 uppercase tracking-widest px-4 py-4">Status</th>
                        <th class="text-right text-xs font-black text-gray-500 uppercase tracking-widest px-6 py-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-white/3 transition-colors group">
                            <td class="px-6 py-4">
                                <p class="font-bold text-white text-sm">#@item.Id</p>
                            </td>
                            <td class="px-4 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary shrink-0">
                                        <span class="material-symbols-outlined text-xl">person</span>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-semibold text-white text-sm truncate">@(item.User?.FullName ?? "Anonymous")</p>
                                        <p class="text-xs text-gray-500 truncate">@item.User?.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-4">
                                @if (!string.IsNullOrEmpty(item.Address))
                                {
                                    var parts = item.Address.Split('|');
                                    var gov = parts.FirstOrDefault()?.Trim() ?? "—";
                                    <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full font-semibold bg-blue-500/10 text-blue-400 border border-blue-500/20" title="@item.Address">
                                        <span class="material-symbols-outlined text-xs">location_on</span>
                                        @gov
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-600 text-xs">—</span>
                                }
                            </td>
                            <td class="px-4 py-4">
                                <p class="text-gray-400 text-sm">@item.Name</p>
                            </td>
                            <td class="px-4 py-4">
                                <p class="text-white font-bold text-sm">@item.tootal_amount.ToString("C")</p>
                            </td>
                            <td class="px-4 py-4">
                                @{
                                    // Explicitly check against the enum values
                                    var statusClass = item.Status == ecommerce_system.Models.OrderStatus.Completed ? "bg-green-500/10 text-green-400 border-green-500/20" :
                                                      item.Status == ecommerce_system.Models.OrderStatus.Pending ? "bg-yellow-500/10 text-yellow-400 border-yellow-500/20" :
                                                      item.Status == ecommerce_system.Models.OrderStatus.Cancelled ? "bg-red-500/10 text-red-400 border-red-500/20" :
                                                      "bg-blue-500/10 text-blue-400 border-blue-500/20"; // Covers Processing / Paid
                                }
                                <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full font-bold border @statusClass">
                                    @item.Status
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 hover:bg-primary/20 hover:text-primary text-gray-400 transition-all" title="View Details">
                                        <span class="material-symbols-outlined text-base">visibility</span>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 hover:bg-admin-accent/20 hover:text-admin-accent text-gray-400 transition-all" title="Edit">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 hover:bg-red-500/20 hover:text-red-400 text-gray-400 transition-all" title="Delete">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
