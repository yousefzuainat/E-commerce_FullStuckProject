@model IEnumerable<ecommerce_system.Models.order>

@{
    ViewData["Title"] = "Orders Management";
}

<div class="container-fluid px-4 py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-0 text-gray-800">Orders Management</h1>
            <p class="text-muted">Manage and track customer orders</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small fw-bold">
                        <tr>
                            <th class="ps-4">ORDER ID</th>
                            <th>CUSTOMER</th>
                            <th>DATE</th>
                            <th>TOTAL AMOUNT</th>
                            <th>STATUS</th>
                            <th class="text-end pe-4">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.Id</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                            <i class="fas fa-user small"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@(item.User?.UserName ?? "Anonymous")</div>
                                            <div class="text-muted small">@item.User?.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted">@item.Name</td>
                                <td class="fw-bold">@item.tootal_amount.ToString("C")</td>
                                <td>
                                    <span class="badge rounded-pill @(item.Status == "Completed" ? "bg-success" : item.Status == "Pending" ? "bg-warning text-dark" : item.Status == "Cancelled" ? "bg-danger" : "bg-info") px-3">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-white btn-sm px-3 border-end" title="View Details">
                                            <i class="fas fa-eye text-primary"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white btn-sm px-3 border-end" title="Edit Order">
                                            <i class="fas fa-edit text-info"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-white btn-sm px-3 text-danger" title="Delete Order">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table thead th {
            letter-spacing: 0.05em;
            padding-top: 1rem;
            padding-bottom: 1rem;
        }
        .btn-white {
            background-color: #fff;
            color: #444;
        }
        .btn-white:hover {
            background-color: #f8f9fa;
        }
        .bg-primary-subtle {
            background-color: #e7f1ff;
         }
    </style>
}
