@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-wrap">
    <div class="auth-card">
        <span class="auth-eye">New Account</span>
        <h1 class="auth-heading">Join Voltex.</h1>
        <p class="auth-sub">Create your account — it only takes a minute.</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <div class="auth-field">
                <label asp-for="Input.FullName" class="auth-label">Full Name</label>
                <input asp-for="Input.FullName" class="auth-input" aria-required="true" placeholder="Jane Doe" />
                <span asp-validation-for="Input.FullName" class="auth-field-err"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Email" class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="username"
                       aria-required="true" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="auth-field-err"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password" class="auth-label">Password</label>
                <input asp-for="Input.Password" class="auth-input" autocomplete="new-password"
                       aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="auth-field-err"></span>
            </div>

            <div class="auth-field" style="margin-bottom:2rem">
                <label asp-for="Input.ConfirmPassword" class="auth-label">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="auth-input" autocomplete="new-password"
                       aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="auth-field-err"></span>
            </div>

            <button id="registerSubmit" type="submit" class="auth-submit">Create Account</button>

            <div class="auth-links">
                <a asp-area="Identity" asp-page="/Account/Login" class="auth-link-primary">
                    Already have an account? Sign in
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
